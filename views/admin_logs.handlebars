<div class="container py-4">
    {{#if mensagem}}
    <div class="alert alert-{{tipoMensagem}} alert-autodismiss" role="alert">
        {{#if (eq tipoMensagem 'danger')}}<i class="fa-solid fa-circle-xmark"></i>{{else}}<i class="fa-solid fa-circle-check"></i>{{/if}} {{mensagem}}
    </div>
    {{/if}}

    {{#if logCleanupWarning}}
    <div class="alert alert-warning border" role="alert">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <strong><i class="fa-solid fa-triangle-exclamation"></i> Limpeza de log recomendada</strong>
                <div class="small mt-1">
                    Foram detectados {{logCleanupWarning.logCount}} registros (limite recomendado: {{logCleanupWarning.maxRecords}}).
                    O sistema continuará registrando novas atividades até você executar a limpeza completa.
                </div>
            </div>
            <form method="post" action="{{logCleanupWarning.cleanupUrl}}" class="m-0" id="formExecutarLimpezaLog">
                <button type="submit" class="btn btn-danger">
                    <i class="fa-solid fa-broom"></i> Executar limpeza de log
                </button>
            </form>
        </div>
    </div>
    {{/if}}

    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
        <div>
            <h1 class="mb-1">Log de atividades</h1>
            <div class="text-body-secondary">Registros de requisições à aplicação (administrador).</div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h2 class="h6 text-body-secondary mb-3">Filtros</h2>
            <form method="get" action="/admin/logs" class="row g-3 align-items-end">
                <div class="col-12 col-md-6 col-lg-3">
                    <label for="filtroDataInicio" class="form-label">Data inicial</label>
                    <input type="date" class="form-control" id="filtroDataInicio" name="data_inicio" value="{{filter.data_inicio}}">
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <label for="filtroDataFim" class="form-label">Data final</label>
                    <input type="date" class="form-control" id="filtroDataFim" name="data_fim" value="{{filter.data_fim}}">
                </div>
                <div class="col-12 col-md-6 col-lg-2">
                    <label for="filtroStatus" class="form-label">Status</label>
                    <select class="form-select" id="filtroStatus" name="status">
                        <option value="todos" {{#if filter.statusTodos}}selected{{/if}}>Todos</option>
                        <option value="sucesso" {{#if filter.statusSucesso}}selected{{/if}}>Sucesso</option>
                        <option value="falha" {{#if filter.statusFalha}}selected{{/if}}>Falha</option>
                    </select>
                </div>
                <div class="col-12 col-md-6 col-lg-2">
                    <label for="filtroUsuario" class="form-label">Usuário</label>
                    <select class="form-select" id="filtroUsuario" name="user_code">
                        <option value="todos" {{#if filter.userTodos}}selected{{/if}}>Todos</option>
                        {{#each userFilterOptions}}
                            <option value="{{code}}" {{#if selected}}selected{{/if}}>{{#if name}}{{name}} ({{code}}){{else}}{{code}}{{/if}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="col-12 col-md-6 col-lg-2">
                    <label for="filtroPerPage" class="form-label">Itens por página</label>
                    <select class="form-select" id="filtroPerPage" name="per_page">
                        <option value="10" {{#if filter.per10}}selected{{/if}}>10</option>
                        <option value="20" {{#if filter.per20}}selected{{/if}}>20</option>
                        <option value="30" {{#if filter.per30}}selected{{/if}}>30</option>
                        <option value="50" {{#if filter.per50}}selected{{/if}}>50</option>
                    </select>
                </div>
                <div class="col-12 d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-filter me-1"></i> Filtrar
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="btnLimparFiltrosLog">
                        <i class="fa-solid fa-eraser me-1"></i> Limpar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="admin-logs-table-wrap shadow-sm rounded-3 border bg-body">
        <table class="table table-hover table-striped mb-0 align-middle admin-logs-table">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="d-none d-md-table-cell">ID</th>
                    <th scope="col" class="admin-logs-col-datetime">Data/Hora</th>
                    <th scope="col" class="admin-logs-col-user">Usuário</th>
                    <th scope="col" class="admin-logs-col-action">Ação</th>
                    <th scope="col" class="d-none d-md-table-cell">Endpoint</th>
                    <th scope="col" class="admin-logs-col-status">Status</th>
                </tr>
            </thead>
            <tbody>
                {{#if logs.length}}
                    {{#each logs}}
                        <tr
                            class="admin-logs-row"
                            role="button"
                            tabindex="0"
                            aria-label="Ver detalhes do registro {{id}}"
                            data-log-id="{{id}}"
                            data-log-datetime="{{data_hora_label}}"
                            data-log-user="{{user_code_label}}"
                            data-log-user-href="{{user_profile_href}}"
                            data-log-action="{{action}}"
                            data-log-endpoint="{{endpoint}}"
                            data-log-status="{{status}}"
                            data-log-status-label="{{status_label}}"
                        >
                            <td class="text-body-secondary d-none d-md-table-cell">{{id}}</td>
                            <td class="admin-logs-col-datetime">
                                <span class="d-md-none">{{data_hora_label_short}}</span>
                                <span class="d-none d-md-inline text-nowrap">{{data_hora_label}}</span>
                            </td>
                            <td class="admin-logs-col-user">
                                {{#if user_profile_href}}
                                    <a href="{{user_profile_href}}" class="text-decoration-none admin-logs-user-link" title="Ver ficha completa do cadastro"><code>{{user_code_label}}</code></a>
                                {{else}}
                                    <code>{{user_code_label}}</code>
                                {{/if}}
                            </td>
                            <td class="admin-logs-col-action"><span class="badge bg-secondary-subtle text-secondary-emphasis border">{{action}}</span></td>
                            <td class="text-break d-none d-md-table-cell"><small>{{endpoint}}</small></td>
                            <td class="admin-logs-col-status">
                                <span class="d-md-none">
                                    {{#if (eq status 'SUCESSO')}}
                                        <span class="badge bg-success" title="Sucesso">S</span>
                                    {{else}}
                                        <span class="badge bg-danger" title="Falha">F</span>
                                    {{/if}}
                                </span>
                                <span class="d-none d-md-inline {{status_class}} fw-semibold">{{status_label}}</span>
                            </td>
                        </tr>
                    {{/each}}
                {{else}}
                    <tr>
                        <td colspan="6" class="text-center text-body-secondary py-4">Nenhum registro encontrado para os filtros informados.</td>
                    </tr>
                {{/if}}
            </tbody>
        </table>
    </div>

    <div
        class="admin-logs-pagination-wrapper d-flex flex-column align-items-center gap-2 mt-4"
        data-log-pagination-root
        data-query-no-page="{{logsQueryStringNoPage}}"
    >
        <small class="text-body-secondary">Total de registros: {{pagination.totalItems}}</small>

        {{#if pagination.totalPages}}
        <div class="w-100 d-flex justify-content-center px-2" style="max-width: 100%;">
            <div class="admin-logs-pagination-inner w-100" style="max-width: 100%;">
                <nav class="admin-logs-pagination-nav d-flex justify-content-center" data-log-pagination-nav aria-label="Paginação do log">
                    <ul class="pagination pagination-sm mb-0 flex-nowrap" data-log-pagination-ul>
                        <li class="page-item {{#unless pagination.hasPrev}}disabled{{/unless}}">
                            <a class="page-link" href="{{pagination.prevHref}}" aria-label="Página anterior">Anterior</a>
                        </li>
                        {{#each pagination.pageNumbers}}
                            <li class="page-item {{#if isCurrent}}active{{/if}}">
                                <a class="page-link" href="{{href}}">{{number}}</a>
                            </li>
                        {{/each}}
                        <li class="page-item {{#unless pagination.hasNext}}disabled{{/unless}}">
                            <a class="page-link" href="{{pagination.nextHref}}" aria-label="Próxima página">Próxima</a>
                        </li>
                    </ul>
                </nav>
                <div class="admin-logs-pagination-select d-none justify-content-center align-items-center gap-2" data-log-pagination-select-wrap>
                    <label for="adminLogsPageSelect" class="form-label mb-0 small text-body-secondary">Página</label>
                    <select id="adminLogsPageSelect" class="form-select form-select-sm w-auto" data-log-pagination-select style="min-width: 8rem;">
                        {{#each pagination.selectPages}}
                            <option value="{{number}}" {{#if isCurrent}}selected{{/if}}>Página {{number}} de {{../pagination.totalPages}}</option>
                        {{/each}}
                    </select>
                </div>
            </div>
        </div>
        {{/if}}
    </div>
</div>

<div class="modal fade" id="adminLogDetailModal" tabindex="-1" aria-labelledby="adminLogDetailModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="adminLogDetailModalLabel">Detalhes do registro</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <dl class="row mb-0 small">
                    <dt class="col-sm-4 text-body-secondary">ID</dt>
                    <dd class="col-sm-8" id="adminLogModalId">—</dd>

                    <dt class="col-sm-4 text-body-secondary">Data/Hora</dt>
                    <dd class="col-sm-8 text-nowrap" id="adminLogModalDatetime">—</dd>

                    <dt class="col-sm-4 text-body-secondary">Usuário</dt>
                    <dd class="col-sm-8" id="adminLogModalUser">—</dd>

                    <dt class="col-sm-4 text-body-secondary">Ação</dt>
                    <dd class="col-sm-8" id="adminLogModalAction">—</dd>

                    <dt class="col-sm-4 text-body-secondary">Endpoint</dt>
                    <dd class="col-sm-8 text-break" id="adminLogModalEndpoint">—</dd>

                    <dt class="col-sm-4 text-body-secondary">Status</dt>
                    <dd class="col-sm-8" id="adminLogModalStatus">—</dd>
                </dl>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-logs-row {
        cursor: pointer;
    }

    .admin-logs-row:focus-visible {
        outline: 2px solid var(--bs-primary);
        outline-offset: -2px;
    }

    @media (min-width: 768px) {
        .admin-logs-table-wrap {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
    }

    @media (max-width: 767.98px) {
        .admin-logs-table-wrap {
            overflow-x: hidden;
        }

        .admin-logs-table {
            width: 100%;
            table-layout: fixed;
        }

        .admin-logs-table th,
        .admin-logs-table td {
            padding-left: 0.35rem;
            padding-right: 0.35rem;
            font-size: 0.875rem;
        }

        .admin-logs-col-datetime {
            width: 42%;
            white-space: nowrap;
        }

        .admin-logs-col-user {
            width: 20%;
            overflow-wrap: anywhere;
        }

        .admin-logs-col-action {
            width: 24%;
            overflow-wrap: anywhere;
        }

        .admin-logs-col-status {
            width: 14%;
            text-align: center;
        }

        .admin-logs-col-user code {
            font-size: 0.8em;
            word-break: break-all;
        }

        .admin-logs-col-action .badge {
            font-size: 0.7rem;
            padding: 0.2em 0.35em;
        }
    }

    .admin-logs-pagination-inner {
        max-width: 100%;
    }

    .admin-logs-pagination-nav {
        max-width: 100%;
        overflow: hidden;
    }

    .admin-logs-pagination-nav .pagination {
        flex-wrap: nowrap;
    }
</style>

<script>
    (() => {
        const btnLimpar = document.getElementById('btnLimparFiltrosLog');
        if (btnLimpar) {
            btnLimpar.addEventListener('click', () => {
                window.location.href = '{{clearLogsUrl}}';
            });
        }

        const formLimpeza = document.getElementById('formExecutarLimpezaLog');
        if (formLimpeza) {
            formLimpeza.addEventListener('submit', (event) => {
                const confirmed = window.confirm(
                    'Confirma a limpeza completa do log? Todos os registros serão removidos (TRUNCATE).'
                );
                if (!confirmed) {
                    event.preventDefault();
                }
            });
        }

        const modalEl = document.getElementById('adminLogDetailModal');
        const logRows = document.querySelectorAll('.admin-logs-row');

        function fillLogDetailModal(row) {
            const ds = row.dataset;
            const elId = document.getElementById('adminLogModalId');
            const elDatetime = document.getElementById('adminLogModalDatetime');
            const elUser = document.getElementById('adminLogModalUser');
            const elAction = document.getElementById('adminLogModalAction');
            const elEndpoint = document.getElementById('adminLogModalEndpoint');
            const elStatus = document.getElementById('adminLogModalStatus');

            if (elId) elId.textContent = ds.logId || '—';
            if (elDatetime) elDatetime.textContent = ds.logDatetime || '—';

            if (elUser) {
                const userCode = ds.logUser || '—';
                const userHref = ds.logUserHref || '';
                elUser.replaceChildren();
                const codeEl = document.createElement('code');
                codeEl.textContent = userCode;
                if (userHref) {
                    const link = document.createElement('a');
                    link.href = userHref;
                    link.className = 'text-decoration-none';
                    link.title = 'Ver ficha completa do cadastro';
                    link.appendChild(codeEl);
                    elUser.appendChild(link);
                } else {
                    elUser.appendChild(codeEl);
                }
            }

            if (elAction) {
                const action = ds.logAction || '—';
                elAction.replaceChildren();
                const badge = document.createElement('span');
                badge.className = 'badge bg-secondary-subtle text-secondary-emphasis border';
                badge.textContent = action;
                elAction.appendChild(badge);
            }

            if (elEndpoint) elEndpoint.textContent = ds.logEndpoint || '—';

            if (elStatus) {
                const status = ds.logStatus || '';
                const statusLabel = ds.logStatusLabel || '—';
                const isSuccess = status === 'SUCESSO';
                elStatus.replaceChildren();
                const badge = document.createElement('span');
                badge.className = `badge ${isSuccess ? 'bg-success' : 'bg-danger'}`;
                badge.textContent = statusLabel;
                elStatus.appendChild(badge);
            }
        }

        function openLogDetailModal(row) {
            if (!modalEl || !window.bootstrap || !bootstrap.Modal) return;
            fillLogDetailModal(row);
            bootstrap.Modal.getOrCreateInstance(modalEl).show();
        }

        logRows.forEach((row) => {
            row.addEventListener('click', (e) => {
                if (e.target.closest('a')) return;
                openLogDetailModal(row);
            });
            row.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    openLogDetailModal(row);
                }
            });
        });

        document.querySelectorAll('.admin-logs-user-link').forEach((link) => {
            link.addEventListener('click', (e) => e.stopPropagation());
        });

        const root = document.querySelector('[data-log-pagination-root]');
        if (!root) return;

        const nav = root.querySelector('[data-log-pagination-nav]');
        const ul = root.querySelector('[data-log-pagination-ul]');
        const selectWrap = root.querySelector('[data-log-pagination-select-wrap]');
        const select = root.querySelector('[data-log-pagination-select]');

        function goToPage(pageNum) {
            const base = root.getAttribute('data-query-no-page') || '';
            const p = new URLSearchParams(base);
            p.set('page', String(pageNum));
            const tail = p.toString();
            window.location.href = tail ? '/admin/logs?' + tail : '/admin/logs?page=' + encodeURIComponent(pageNum);
        }

        if (select) {
            select.addEventListener('change', () => {
                goToPage(select.value);
            });
        }

        function syncPaginationMode() {
            if (!nav || !ul || !selectWrap) return;
            nav.classList.remove('d-none');
            selectWrap.classList.add('d-none');
            selectWrap.classList.remove('d-flex');
            const overflows = ul.scrollWidth > ul.clientWidth + 1;
            if (overflows) {
                nav.classList.add('d-none');
                selectWrap.classList.remove('d-none');
                selectWrap.classList.add('d-flex');
            }
        }

        const ro = typeof ResizeObserver !== 'undefined' ? new ResizeObserver(() => syncPaginationMode()) : null;
        if (ro) ro.observe(root);
        window.addEventListener('resize', syncPaginationMode);
        syncPaginationMode();
    })();
</script>
