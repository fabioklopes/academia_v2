</div>

<script>
    (function() {
        const modal = document.getElementById('alunoModal');
        if (!modal) {
            return;
        }

        const avatarLightbox = document.getElementById('alunoAvatarLightbox');
        const avatarLightboxImg = document.getElementById('alunoAvatarLightboxImg');
        const avatarLightboxBtn = document.getElementById('modalAlunoPhotoBtn');

        function closeAlunoAvatarLightbox() {
            if (!avatarLightbox) {
                return;
            }
            avatarLightbox.classList.remove('is-open');
            avatarLightbox.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        function openAlunoAvatarLightbox(srcOverride) {
            if (!avatarLightbox || !avatarLightboxImg) {
                return;
            }
            if (srcOverride) {
                avatarLightboxImg.src = srcOverride;
                avatarLightboxImg.alt = 'Foto do aluno';
            } else {
                const photo = document.getElementById('modalAlunoPhoto');
                if (!photo || !photo.getAttribute('src')) return;
                avatarLightboxImg.src = photo.currentSrc || photo.src;
                avatarLightboxImg.alt = photo.alt || 'Foto do aluno';
            }
            avatarLightbox.classList.add('is-open');
            avatarLightbox.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        if (avatarLightboxBtn) {
            avatarLightboxBtn.addEventListener('click', function(e) {
                e.preventDefault();
                openAlunoAvatarLightbox();
            });
        }

        document.querySelectorAll('.aluno-avatar').forEach(function(img) {
            img.addEventListener('click', function(e) {
                e.stopPropagation();
                const src = img.getAttribute('src');
                if (src) openAlunoAvatarLightbox(src);
            });
        });

        if (avatarLightbox) {
            avatarLightbox.addEventListener('click', function(e) {
                if (e.target === avatarLightbox || (e.target && e.target.closest && e.target.closest('.aluno-avatar-lightbox-close'))) {
                    closeAlunoAvatarLightbox();
                }
            });
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && avatarLightbox && avatarLightbox.classList.contains('is-open')) {
                closeAlunoAvatarLightbox();
            }
        });

        let lastTrigger = null;
        let showExcluirConfirmAfterAlunoModalHidden = false;

        const setText = (id, value) => {
            const el = document.getElementById(id);
            if (el) {
                el.textContent = value && String(value).trim() !== '' ? value : '-';
            }
        };

        modal.addEventListener('show.bs.modal', async function(event) {
            const trigger = event.relatedTarget;
            lastTrigger = trigger || null;
            if (!trigger) {
                return;
            }

            const alunoId = trigger.getAttribute('data-id');

            const firstName = trigger.getAttribute('data-first-name') || '';
            const lastName = trigger.getAttribute('data-last-name') || '';
            const fullName = `${firstName} ${lastName}`.trim();

            const modalPhoto = document.getElementById('modalAlunoPhoto');
            if (modalPhoto) {
                modalPhoto.src = trigger.getAttribute('data-photo') || '/uploads/users/default.jpg';
                modalPhoto.alt = `Avatar de ${fullName || 'aluno'}`;
            }

            setText('modalAlunoNome', fullName || '-');
            setText('modalAlunoEmail', trigger.getAttribute('data-email'));
            setText('modalAlunoRole', trigger.getAttribute('data-role'));
            setText('modalAlunoPresencas', '-');
            setText('modalAlunoPresencasPeriodo', '');
            setText('modalAlunoPhone', trigger.getAttribute('data-phone'));
            setText('modalAlunoBirth', trigger.getAttribute('data-birth-date'));
            setText('modalAlunoBeltSummary', trigger.getAttribute('data-belt-summary'));
            setText('modalAlunoWagi', trigger.getAttribute('data-wagi'));
            setText('modalAlunoZubon', trigger.getAttribute('data-zubon'));
            setText('modalAlunoObi', trigger.getAttribute('data-obi'));

            // Presenças (sem ponderação) dentro do período da meta de aula vigente do aluno
            if (alunoId) {
                try {
                    const res = await fetch(`/aluno/${alunoId}/meta-atual`, { method: 'GET' });
                    if (res.ok) {
                        const payload = await res.json();
                        const progress = payload ? payload.progress : null;
                        const total = payload ? payload.presencasCount : null;
                        setText('modalAlunoPresencas', Number.isFinite(total) ? String(total) : '-');

                        const toBr = (iso) => {
                            if (!iso || typeof iso !== 'string') return '';
                            const [y, m, d] = iso.split('-');
                            return (y && m && d) ? `${d}/${m}/${y}` : '';
                        };
                        const periodoEl = document.getElementById('modalAlunoPresencasPeriodo');
                        if (periodoEl) {
                            if (progress && progress.hasMeta) {
                                const inicio = toBr(progress.startDate);
                                const fim = toBr(progress.endDate);
                                periodoEl.textContent = `Meta vigente: ${inicio} à ${fim}`;
                            } else {
                                periodoEl.textContent = 'Sem meta de aula vigente';
                            }
                        }
                    }
                } catch (_e) {
                    // silencioso: mantém "-"
                }
            }

            // Configurar responsável como link
            const responsibleLink = document.getElementById('modalAlunoResponsibleLink');
            const responsibleName = trigger.getAttribute('data-responsible-name');
            if (responsibleName && responsibleLink) {
                responsibleLink.textContent = responsibleName;
                responsibleLink.href = '#';
                responsibleLink.className = 'text-decoration-none text-primary';
                responsibleLink.onclick = function(e) {
                    e.preventDefault();
                    showResponsibleModal(trigger);
                };
            } else if (responsibleLink) {
                responsibleLink.textContent = '-';
                responsibleLink.href = '#';
                responsibleLink.onclick = null;
            }

            const statusCode = trigger.getAttribute('data-status-code') || '';
            const roleCode = (trigger.getAttribute('data-role-code') || '').trim().toUpperCase();

            const professorSwitch = document.getElementById('alunoProfessorSwitch');
            const professorLabel = document.getElementById('alunoProfessorLabel');
            const professorContainer = document.getElementById('alunoProfessorSwitchContainer');
            if (professorSwitch && professorContainer && professorLabel) {
                const isProf = roleCode === 'PRO';
                professorSwitch.checked = isProf;
                professorSwitch.dataset.userId = alunoId || '';
                professorSwitch.dataset.originalIsProfessor = isProf ? '1' : '0';
                const cannotPromoteStudent = roleCode === 'STD' && statusCode !== 'A';
                professorSwitch.disabled = roleCode === 'ADM' || cannotPromoteStudent;
                if (roleCode === 'ADM') {
                    professorSwitch.title = 'O perfil de administrador não pode ser alterado aqui.';
                } else if (cannotPromoteStudent) {
                    professorSwitch.title = 'Somente alunos ativos podem ser promovidos a professor.';
                } else {
                    professorSwitch.title = '';
                }
                professorContainer.classList.remove('text-success', 'text-danger', 'text-primary');
                if (isProf) {
                    professorLabel.textContent = 'Sim';
                    professorContainer.classList.add('text-success');
                } else {
                    professorLabel.textContent = 'Não';
                    professorContainer.classList.add('text-primary');
                }
            }

            // Configurar switch de status
            const statusSwitch = document.getElementById('alunoStatusSwitch');
            const statusLabel = document.getElementById('alunoStatusLabel');
            const switchContainer = document.getElementById('alunoStatusSwitchContainer');
            
            if (statusSwitch && switchContainer) {
                statusSwitch.checked = statusCode === 'A';
                statusSwitch.dataset.alunoId = alunoId;
                statusSwitch.dataset.originalStatus = statusCode;
                
                // Remover cores anteriores
                switchContainer.classList.remove('text-success', 'text-danger');
                
                // Aplicar cor baseada no status
                if (statusCode === 'A') {
                    statusLabel.textContent = 'Ativo';
                    switchContainer.classList.add('text-success');
                } else if (statusCode === 'C') {
                    statusLabel.textContent = 'Cancelado';
                    switchContainer.classList.add('text-danger');
                } else {
                    statusLabel.textContent = 'Pendente';
                }
            }

            const excluirWrap = document.getElementById('alunoExcluirWrap');
            if (excluirWrap) {
                excluirWrap.classList.toggle('d-none', roleCode !== 'STD');
            }

            const modalBeltImage = document.getElementById('modalAlunoBeltImage');
            if (modalBeltImage) {
                const beltImagePath = trigger.getAttribute('data-belt-image') || '/img/belts/white_0.png';
                const beltLabel = trigger.getAttribute('data-belt-label') || 'Faixa';
                const beltValue = trigger.getAttribute('data-belt') || 'white';

                modalBeltImage.onerror = function() {
                    this.onerror = null;
                    this.src = `/img/belts/${beltValue}_0.png`;
                };
                modalBeltImage.src = beltImagePath;
                modalBeltImage.alt = `Faixa ${beltLabel}`;
            }
        });

        modal.addEventListener('hide.bs.modal', function() {
            const focusedElement = document.activeElement;
            if (focusedElement && modal.contains(focusedElement) && typeof focusedElement.blur === 'function') {
                focusedElement.blur();
            }
        });

        modal.addEventListener('hidden.bs.modal', function() {
            closeAlunoAvatarLightbox();
            if (showExcluirConfirmAfterAlunoModalHidden) {
                showExcluirConfirmAfterAlunoModalHidden = false;
                const elConfirm = document.getElementById('modalAlunoExcluirConfirmar');
                if (elConfirm && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                    bootstrap.Modal.getOrCreateInstance(elConfirm).show();
                }
                return;
            }
            if (lastTrigger && document.contains(lastTrigger) && typeof lastTrigger.focus === 'function') {
                lastTrigger.focus();
            }
        });

        const professorSwitchEl = document.getElementById('alunoProfessorSwitch');
        if (professorSwitchEl) {
            professorSwitchEl.addEventListener('change', async function() {
                const userId = this.dataset.userId;
                const original = this.dataset.originalIsProfessor === '1';
                const wantProfessor = this.checked;
                if (!userId) {
                    return;
                }
                if (wantProfessor === original) {
                    return;
                }
                this.disabled = true;
                try {
                    const response = await fetch('/promoveraluno', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ userId: userId, isProfessor: wantProfessor })
                    });
                    const data = await response.json().catch(function() { return {}; });
                    if (!response.ok || !data.ok) {
                        throw new Error(data.error || 'Erro ao atualizar perfil de professor.');
                    }
                    const modalInst = bootstrap.Modal.getInstance(document.getElementById('alunoModal'));
                    if (modalInst) {
                        modalInst.hide();
                    }
                    setTimeout(function() {
                        location.reload();
                    }, 500);
                } catch (error) {
                    console.error('Erro:', error);
                    alert('Erro ao atualizar status de professor: ' + error.message);
                    this.checked = original;
                    const lbl = document.getElementById('alunoProfessorLabel');
                    const cont = document.getElementById('alunoProfessorSwitchContainer');
                    if (lbl) {
                        lbl.textContent = original ? 'Sim' : 'Não';
                    }
                    if (cont) {
                        cont.classList.remove('text-success', 'text-primary');
                        cont.classList.add(original ? 'text-success' : 'text-primary');
                    }
                    this.disabled = false;
                }
            });
        }

        // Listener para o switch de ativação/desativação
        const statusSwitch = document.getElementById('alunoStatusSwitch');
        if (statusSwitch) {
            statusSwitch.addEventListener('change', async function() {
                const alunoId = this.dataset.alunoId;
                const originalStatus = this.dataset.originalStatus;
                let newStatus;

                // Determinar novo status baseado na ação do switch
                if (this.checked) {
                    newStatus = 'A'; // Checkbox marcado = Ativo
                } else {
                    newStatus = originalStatus === 'A' ? 'C' : 'A'; // Desmarcado
                }

                try {
                    const response = await fetch(`/aluno/status/${alunoId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ newStatus })
                    });

                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.error || 'Erro ao atualizar status');
                    }

                    const result = await response.json();
                    
                    // Fechar modal para recarregar dados
                    const modal = bootstrap.Modal.getInstance(document.getElementById('alunoModal'));
                    if (modal) {
                        modal.hide();
                    }
                    
                    // Recarregar a página após 500ms para permitir o modal fechar
                    setTimeout(() => {
                        location.reload();
                    }, 500);
                } catch (error) {
                    console.error('Erro:', error);
                    alert('Erro ao atualizar status do aluno: ' + error.message);
                    this.checked = originalStatus === 'A';
                }
            });
        }

        let pendingExcluirAlunoId = null;
        let abrirSenhaAposFecharConfirm = false;

        const btnAlunoExcluir = document.getElementById('btnAlunoExcluir');
        const modalAlunoExcluirConfirmar = document.getElementById('modalAlunoExcluirConfirmar');
        const modalAlunoExcluirSenha = document.getElementById('modalAlunoExcluirSenha');
        const alunoExcluirConfirmBody = document.getElementById('alunoExcluirConfirmBody');
        const btnAlunoExcluirConfirmar = document.getElementById('btnAlunoExcluirConfirmar');
        const alunoExcluirSenhaInput = document.getElementById('alunoExcluirSenhaInput');
        const alunoExcluirSenhaErro = document.getElementById('alunoExcluirSenhaErro');
        const btnAlunoExcluirSenhaEnviar = document.getElementById('btnAlunoExcluirSenhaEnviar');

        function hideSenhaExcluirErro() {
            if (!alunoExcluirSenhaErro) {
                return;
            }
            alunoExcluirSenhaErro.textContent = '';
            alunoExcluirSenhaErro.classList.add('d-none');
        }

        function showSenhaExcluirErro(msg) {
            if (!alunoExcluirSenhaErro) {
                return;
            }
            alunoExcluirSenhaErro.textContent = msg;
            alunoExcluirSenhaErro.classList.remove('d-none');
        }

        if (btnAlunoExcluir && modalAlunoExcluirConfirmar && alunoExcluirConfirmBody) {
            btnAlunoExcluir.addEventListener('click', function() {
                if (typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                    return;
                }
                const t = lastTrigger;
                if (!t) {
                    return;
                }
                const roleCode = (t.getAttribute('data-role-code') || '').trim().toUpperCase();
                if (roleCode !== 'STD') {
                    return;
                }
                const id = t.getAttribute('data-id');
                const firstName = t.getAttribute('data-first-name') || '';
                const lastName = t.getAttribute('data-last-name') || '';
                const fullName = (firstName + ' ' + lastName).trim() || 'aluno';
                pendingExcluirAlunoId = id;
                const texto = 'Se confirmar a exclusão do aluno ' + fullName + ' todas as informações (inclusive seu cadastro) serão perdidas. O aluno não terá mais acesso ao sistema a não ser que uma nova solicitação de acesso seja aprovada.';
                alunoExcluirConfirmBody.textContent = texto;
                showExcluirConfirmAfterAlunoModalHidden = true;
                const alunoModalInst = bootstrap.Modal.getInstance(modal) || bootstrap.Modal.getOrCreateInstance(modal);
                alunoModalInst.hide();
            });

            if (btnAlunoExcluirConfirmar && modalAlunoExcluirSenha) {
                btnAlunoExcluirConfirmar.addEventListener('click', function() {
                    if (typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                        return;
                    }
                    hideSenhaExcluirErro();
                    abrirSenhaAposFecharConfirm = true;
                    const inst = bootstrap.Modal.getInstance(modalAlunoExcluirConfirmar)
                        || bootstrap.Modal.getOrCreateInstance(modalAlunoExcluirConfirmar);
                    inst.hide();
                });

                modalAlunoExcluirConfirmar.addEventListener('hidden.bs.modal', function() {
                    if (abrirSenhaAposFecharConfirm) {
                        abrirSenhaAposFecharConfirm = false;
                        if (alunoExcluirSenhaInput) {
                            alunoExcluirSenhaInput.value = '';
                        }
                        hideSenhaExcluirErro();
                        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                            bootstrap.Modal.getOrCreateInstance(modalAlunoExcluirSenha).show();
                        }
                        requestAnimationFrame(function() {
                            if (alunoExcluirSenhaInput) {
                                alunoExcluirSenhaInput.focus();
                            }
                        });
                        return;
                    }
                    pendingExcluirAlunoId = null;
                });
            }

            if (btnAlunoExcluirSenhaEnviar && alunoExcluirSenhaInput) {
                async function enviarExclusaoAluno() {
                    hideSenhaExcluirErro();
                    const pw = alunoExcluirSenhaInput.value;
                    if (!pw) {
                        showSenhaExcluirErro('Informe a senha.');
                        return;
                    }
                    if (!pendingExcluirAlunoId) {
                        showSenhaExcluirErro('Sessão de exclusão inválida. Feche e tente novamente.');
                        return;
                    }
                    btnAlunoExcluirSenhaEnviar.disabled = true;
                    try {
                        const res = await fetch('/aluno/excluir/' + encodeURIComponent(pendingExcluirAlunoId), {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ password: pw })
                        });
                        const data = await res.json().catch(function() { return {}; });
                        if (!res.ok || !data.ok) {
                            throw new Error(data.error || 'Não foi possível excluir o aluno.');
                        }
                        if (typeof bootstrap !== 'undefined' && bootstrap.Modal && modalAlunoExcluirSenha) {
                            const senhaInst = bootstrap.Modal.getInstance(modalAlunoExcluirSenha);
                            if (senhaInst) {
                                senhaInst.hide();
                            }
                        }
                        const msg = data.message || 'Aluno excluído com sucesso.';
                        window.location.href = '/aluno?mensagem=' + encodeURIComponent(msg) + '&tipo=sucesso';
                    } catch (e) {
                        showSenhaExcluirErro(e.message || 'Erro ao excluir.');
                    } finally {
                        btnAlunoExcluirSenhaEnviar.disabled = false;
                    }
                }

                btnAlunoExcluirSenhaEnviar.addEventListener('click', function() {
                    enviarExclusaoAluno();
                });

                alunoExcluirSenhaInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        enviarExclusaoAluno();
                    }
                });
            }

            if (modalAlunoExcluirSenha) {
                modalAlunoExcluirSenha.addEventListener('hidden.bs.modal', function() {
                    hideSenhaExcluirErro();
                    if (alunoExcluirSenhaInput) {
                        alunoExcluirSenhaInput.value = '';
                    }
                });
            }
        }

    })();

    // Modal do responsável
    function showResponsibleModal(trigger) {
        const responsibleModal = document.getElementById('responsibleModal');
        if (!responsibleModal) return;

        const setText = (id, value) => {
            const el = document.getElementById(id);
            if (el) {
                el.textContent = value && String(value).trim() !== '' ? value : '-';
            }
        };

        const responsibleName = trigger.getAttribute('data-responsible-name');
        const responsibleEmail = trigger.getAttribute('data-responsible-email');
        const responsibleRole = trigger.getAttribute('data-responsible-role') || '-';
        const responsiblePhone = trigger.getAttribute('data-responsible-phone');
        const responsibleBirth = trigger.getAttribute('data-responsible-birth');
        const responsiblePhoto = trigger.getAttribute('data-responsible-photo') || '/uploads/users/default.jpg';
        const responsibleBeltLabel = trigger.getAttribute('data-responsible-belt-label') || 'Faixa';
        const responsibleBeltSummary = trigger.getAttribute('data-responsible-belt-summary');
        const responsibleBeltImagePath = trigger.getAttribute('data-responsible-belt-image') || '/img/belts/white_0.png';
        const responsibleBelt = trigger.getAttribute('data-responsible-belt') || 'white';
        const responsibleWagi = trigger.getAttribute('data-responsible-wagi');
        const responsibleZubon = trigger.getAttribute('data-responsible-zubon');
        const responsibleObi = trigger.getAttribute('data-responsible-obi');

        const modalPhoto = document.getElementById('modalResponsiblePhoto');
        if (modalPhoto) {
            modalPhoto.src = responsiblePhoto;
            modalPhoto.alt = `Avatar de ${responsibleName || 'responsável'}`;
        }

        setText('modalResponsibleNome', responsibleName || '-');
        setText('modalResponsibleEmail', responsibleEmail);
        setText('modalResponsibleRole', responsibleRole);
        setText('modalResponsiblePhone', responsiblePhone);
        setText('modalResponsibleBirth', responsibleBirth);
        setText('modalResponsibleBeltSummary', responsibleBeltSummary);
        setText('modalResponsibleWagi', responsibleWagi);
        setText('modalResponsibleZubon', responsibleZubon);
        setText('modalResponsibleObi', responsibleObi);

        const modalBeltImage = document.getElementById('modalResponsibleBeltImage');
        if (modalBeltImage) {
            modalBeltImage.onerror = function() {
                this.onerror = null;
                this.src = `/img/belts/${responsibleBelt}_0.png`;
            };
            modalBeltImage.src = responsibleBeltImagePath;
            modalBeltImage.alt = `Faixa ${responsibleBeltLabel}`;
        }

        const bsModal = new bootstrap.Modal(responsibleModal);
        bsModal.show();
    }
</script>

<script>

    // Script de countdown para redirecionamento automático em caso de sucesso
    document.addEventListener('DOMContentLoaded', function () {
        const redirectCountdown = document.getElementById('redirectCountdown');
        if (redirectCountdown) {
            const countdownNumber = document.getElementById('countdownNumber');
            const params = new URLSearchParams(window.location.search);
            const redirectUrl = new URLSearchParams(window.location.search).get('redirect');
            
            // Se há redirecionamento programado (sucesso)
            if (redirectUrl) {
                let timeRemaining = 3; // 3 segundos
                
                const countdownInterval = setInterval(function () {
                    timeRemaining--;
                    countdownNumber.textContent = Math.max(0, timeRemaining);
                    
                    if (timeRemaining <= 0) {
                        clearInterval(countdownInterval);
                        // Redireciona para a URL especificada ou volta à página anterior
                        window.location.href = decodeURIComponent(redirectUrl) || '/aluno';
                    }
                }, 1000);
            }
        }
    });
</script>