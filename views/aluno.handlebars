        box-shadow: 0 0 0 0.25rem var(--bs-focus-ring-color);
    }

    #alunoModal .aluno-modal-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--bs-border-color-translucent);
        display: block;
    }

    .aluno-avatar-lightbox {
        position: fixed;
        inset: 0;
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background: rgba(0, 0, 0, 0.82);
        cursor: zoom-out;
    }

    .aluno-avatar-lightbox.is-open {
        display: flex;
    }

    .aluno-avatar-lightbox img {
        max-width: min(100%, 90vw);
        max-height: min(90vh, 900px);
        width: auto;
        height: auto;
        object-fit: contain;
        border-radius: 0.5rem;
        cursor: default;
        box-shadow: 0 0.5rem 2rem rgba(0, 0, 0, 0.35);
    }

    .aluno-avatar-lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        width: 2.5rem;
        height: 2.5rem;
        border: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        font-size: 1.5rem;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .aluno-avatar-lightbox-close:hover {
        background: rgba(255, 255, 255, 0.28);
    }

    .aluno-search-clear {
        border-radius: 0;
    }

    .aluno-search-submit {
        white-space: nowrap;
    }

    .aluno-novo-badge {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        animation: pulseAlunoNovoBadge 1.4s ease-in-out infinite;
    }

    @keyframes pulseAlunoNovoBadge {
        0% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.55);
        }
        70% {
            transform: scale(1.08);
            box-shadow: 0 0 0 8px rgba(255, 193, 7, 0);
        }
        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(255, 193, 7, 0);
        }
    }
</style>

<form id="alunoSearchForm" method="GET" action="/aluno" class="mb-3">
    <div class="input-group">
        <input
            type="text"
            id="alunoSearchInput"
            name="q"
            class="form-control"
            placeholder="Pesquisar por nome, e-mail, telefone ou código do usuário"
            value="{{searchTerm}}"
            autocomplete="off"
        >
        <button
            type="button"
            id="alunoSearchClear"
            class="btn btn-outline-secondary aluno-search-clear d-none"
            title="Limpar pesquisa"
            aria-label="Limpar pesquisa"
        >
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
        <button type="submit" class="btn btn-primary aluno-search-submit">
            <i class="fa-solid fa-magnifying-glass me-1" aria-hidden="true"></i>
            Pesquisar
        </button>
    </div>
</form>

<script>
    (function () {
        const STORAGE_RESTORE = 'alunoSearchRestore';
        const STORAGE_NO_REFOCUS = 'alunoSearchNoRefocus';

        const form = document.getElementById('alunoSearchForm');
        const input = document.getElementById('alunoSearchInput');
        const clearBtn = document.getElementById('alunoSearchClear');
        if (!form || !input || !clearBtn) {
            return;
        }

        function caretInTrimmed(raw, caret) {
            if (raw == null || caret == null || caret < 0) {
                return 0;
            }
            const lead = raw.length - raw.trimStart().length;
            const trimmed = raw.trim();
            const pos = caret - lead;
            return Math.max(0, Math.min(trimmed.length, pos));
        }

        function updateClearButton() {
            clearBtn.classList.toggle('d-none', input.value.trim() === '');
        }

        if (sessionStorage.getItem(STORAGE_NO_REFOCUS)) {
            sessionStorage.removeItem(STORAGE_NO_REFOCUS);
        } else {
            const rawRestore = sessionStorage.getItem(STORAGE_RESTORE);
            sessionStorage.removeItem(STORAGE_RESTORE);
            if (rawRestore) {
                try {
                    const parsed = JSON.parse(rawRestore);
                    const q = parsed && parsed.q != null ? String(parsed.q) : '';
                    const caret = parsed && typeof parsed.caret === 'number' ? parsed.caret : 0;
                    if (q === input.value.trim()) {
                        requestAnimationFrame(function () {
                            input.focus();
                            const len = input.value.length;
                            const pos = Math.min(Math.max(0, caret), len);
                            input.setSelectionRange(pos, pos);
                        });
                    }
                } catch (_e) {
                    /* ignore */
                }
            }
        }

        updateClearButton();

        function buildAlunoSearchUrl() {
            const q = input.value.trim();
            const params = new URLSearchParams();
            if (q) {
                params.set('q', q);
            }
            const qs = params.toString();
            return qs ? `/aluno?${qs}` : '/aluno';
        }

        function applyAlunoSearch() {
            const next = buildAlunoSearchUrl();
            const current = window.location.pathname + (window.location.search || '');
            if (next === current) {
                return;
            }
            sessionStorage.removeItem(STORAGE_NO_REFOCUS);
            const raw = input.value;
            const q = raw.trim();
            const caret = caretInTrimmed(raw, input.selectionStart != null ? input.selectionStart : q.length);
            sessionStorage.setItem(STORAGE_RESTORE, JSON.stringify({ caret: caret, q: q }));
            window.location.assign(next);
        }

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            applyAlunoSearch();
        });

        input.addEventListener('input', function () {
            updateClearButton();
        });

        clearBtn.addEventListener('click', function () {
            sessionStorage.removeItem(STORAGE_RESTORE);
            sessionStorage.setItem(STORAGE_NO_REFOCUS, '1');
            input.value = '';
            updateClearButton();
            const next = '/aluno';
            const current = window.location.pathname + (window.location.search || '');
            if (next === current) {
                input.blur();
                return;
            }
            window.location.assign(next);
        });
    })();
</script>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Alunos</th>
        </tr>
    </thead>
    <tbody>
        {{#if usuarios.length}}
        {{#each usuarios}}
            <tr>
                <td>
                    <button
                        type="button"
                        class="aluno-link d-inline-flex align-items-center gap-2 border-0 bg-transparent p-0 w-100"
                        data-bs-toggle="modal"
                        data-bs-target="#alunoModal"
                        data-id="{{id}}"
                        data-first-name="{{first_name}}"
                        data-last-name="{{last_name}}"
                        data-email="{{email}}"
                        data-role="{{role_label}}"
                        data-role-code="{{role}}"
                        data-status="{{user_status_label}}"
                        data-status-code="{{user_status}}"
                        data-phone="{{formatPhone phone}}"
                        data-birth-date="{{formatDate birth_date}}"
                        data-belt="{{actual_belt}}"
                        data-degree="{{actual_degree}}"
                        data-belt-label="{{belt_label}}"
                        data-degree-label="{{degree_label}}"
                        data-belt-summary="{{belt_summary_label}}"
                        data-belt-image="{{belt_image_path}}"
                        data-wagi="{{wagi_size}}"
                        data-zubon="{{zubon_size}}"
                        data-obi="{{obi_size}}"
                        data-photo="{{photo}}"
                        {{#if responsavel_dados}}
                        data-responsible-id="{{responsavel_dados.id}}"
                        data-responsible-name="{{responsavel_dados.first_name}} {{responsavel_dados.last_name}}"
                        data-responsible-email="{{responsavel_dados.email}}"
                        data-responsible-role="{{responsavel_dados.role_label}}"
                        data-responsible-phone="{{formatPhone responsavel_dados.phone}}"
                        data-responsible-birth="{{formatDate responsavel_dados.birth_date}}"
                        data-responsible-belt="{{responsavel_dados.actual_belt}}"
                        data-responsible-degree="{{responsavel_dados.actual_degree}}"
                        data-responsible-belt-label="{{responsavel_dados.belt_label}}"
                        data-responsible-belt-summary="{{responsavel_dados.belt_summary_label}}"
                        data-responsible-belt-image="{{responsavel_dados.belt_image_path}}"
                        data-responsible-wagi="{{responsavel_dados.wagi_size}}"
                        data-responsible-zubon="{{responsavel_dados.zubon_size}}"
                        data-responsible-obi="{{responsavel_dados.obi_size}}"
                        data-responsible-photo="{{responsavel_dados.photo}}"
                        {{/if}}
                    >
                        <img src="{{photo}}" alt="Avatar de {{first_name}} {{last_name}}" class="aluno-avatar">
                        <span>{{first_name}} {{last_name}}</span>
                        {{#if can_approve}}
                            <span class="badge bg-warning text-dark aluno-novo-badge ms-1" aria-label="Aluno pendente de aprovação">Novo</span>
                        {{/if}}
                    </button>
                </td>
            </tr>
        {{/each}}
        {{else}}
            <tr>
                <td class="text-center text-body-secondary py-4">
                    Nenhum aluno encontrado para os filtros informados.
                </td>
            </tr>
        {{/if}}
    </tbody>
</table>

<div class="aluno-pagination-wrapper d-flex flex-column align-items-center gap-2 mb-4">
    <small class="text-body-secondary">Total de registros: {{pagination.totalItems}}</small>

    {{#if pagination.totalPages}}
    <nav class="aluno-pagination-nav" aria-label="Paginação de alunos">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item {{#unless pagination.hasPrev}}disabled{{/unless}}">
                <a class="page-link" href="/aluno?page={{pagination.prevPage}}{{#if hasSearchTerm}}&q={{{searchTermEncoded}}}{{/if}}" aria-label="Página anterior">Anterior</a>
            </li>

            {{#each pagination.pageNumbers}}
                <li class="page-item {{#if isCurrent}}active{{/if}}">
                    <a class="page-link" href="/aluno?page={{number}}{{#if ../hasSearchTerm}}&q={{{../searchTermEncoded}}}{{/if}}">{{number}}</a>
                </li>
            {{/each}}

            <li class="page-item {{#unless pagination.hasNext}}disabled{{/unless}}">
                <a class="page-link" href="/aluno?page={{pagination.nextPage}}{{#if hasSearchTerm}}&q={{{searchTermEncoded}}}{{/if}}" aria-label="Próxima página">Próxima</a>
            </li>
        </ul>
    </nav>
    {{/if}}
</div>

