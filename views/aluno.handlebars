        cursor: zoom-in;
        flex-shrink: 0;
    }

    .aluno-link {
        color: inherit;
        text-decoration: none;
        cursor: pointer;
        text-align: left;
    }

    .aluno-link:hover {
        text-decoration: underline;
    }

    .modal-scroll-interno {
        max-height: 55vh;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .modal-scroll-interno::-webkit-scrollbar {
        width: 0;
        height: 0;
    }

    .aluno-detail-label {
        font-weight: 600;
        color: var(--bs-secondary-color);
    }

    .aluno-pagination-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        max-width: 100%;
    }

    .aluno-pagination-wrapper small {
        text-align: center;
    }

    .aluno-pagination-wrapper > * {
        min-width: 0;
    }

    .aluno-pagination-nav {
        display: flex;
        justify-content: center;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

    .aluno-pagination-nav .pagination {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        width: auto;
        margin-bottom: 0;
    }

    @media (max-width: 768px) {
        .aluno-pagination-nav .page-link {
            padding: 0.25rem 0.5rem;
            font-size: 0.85rem;
        }
    }

    .form-check.form-switch.text-success .form-check-input:checked {
        background-color: var(--bs-success);
        border-color: var(--bs-success);
    }

    .form-check.form-switch.text-danger .form-check-input:checked {
        background-color: var(--bs-danger);
        border-color: var(--bs-danger);
    }

    #alunoModal .aluno-modal-avatar-btn {
        line-height: 0;
        border-radius: 50%;
        cursor: zoom-in;
        transition: box-shadow 0.15s ease, transform 0.15s ease;
