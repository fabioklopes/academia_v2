<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <h1 class="mb-0"><i class="fa-solid fa-headset"></i> Fale Conosco</h1>
    <a href="/auth/login" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left"></i> Voltar ao Login
    </a>
</div>

{{#if mensagem}}
<div class="alert {{#if (eq tipoMensagem 'sucesso')}}alert-success{{else}}alert-danger{{/if}} alert-autodismiss" role="alert">
    {{#if (eq tipoMensagem 'sucesso')}}
    <i class="fa-solid fa-circle-check"></i>
    {{else}}
    <i class="fa-solid fa-circle-xmark"></i>
    {{/if}}
    {{mensagem}}
</div>
{{/if}}

<p class="text-muted mb-4">
    Preencha o formulário abaixo e entraremos em contato em breve. Se necessário, você pode anexar um arquivo para
    nos ajudar a entender melhor a sua situação.
</p>

<form action="/contato" method="POST" enctype="multipart/form-data" id="contatoForm" novalidate>

    <div class="form-floating mb-3">
        <input type="text" class="form-control" id="nome" name="nome"
            placeholder="" maxlength="120" required>
        <label for="nome">Nome completo</label>
        <div class="invalid-feedback">Informe seu nome completo.</div>
    </div>

    <div class="form-floating mb-3">
        <input type="tel" class="form-control" id="whatsapp" name="whatsapp"
            placeholder="" inputmode="numeric" maxlength="11"
            autocomplete="tel" pattern="[0-9]{10,11}" required>
        <label for="whatsapp">WhatsApp (apenas números, com DDD)</label>
        <div class="invalid-feedback">Informe um número de WhatsApp válido com DDD (10 ou 11 dígitos).</div>
    </div>

    <div class="form-floating mb-3">
        <input type="email" class="form-control" id="email" name="email"
            placeholder="" autocomplete="email" required>
        <label for="email">E-mail</label>
        <div class="invalid-feedback">Informe um e-mail válido.</div>
    </div>

    <div class="form-floating mb-3">
        <input type="text" class="form-control" id="assunto" name="assunto"
            placeholder="" maxlength="150" required>
        <label for="assunto">Assunto</label>
        <div class="invalid-feedback">Informe o assunto da mensagem.</div>
    </div>

    <div class="mb-3">
        <label for="arquivo" class="form-label">
            Arquivo anexo <span class="text-muted small">(opcional — imagem, PDF ou documento)</span>
        </label>
        <input type="file" class="form-control" id="arquivo" name="arquivo"
            accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.txt">
        <div class="form-text text-muted">Tamanho máximo: 10 MB.</div>
    </div>

    <div class="mb-4">
        <label for="mensagem" class="form-label">
            Mensagem <span class="text-danger">*</span>
        </label>
        <textarea class="form-control" id="mensagem" name="mensagem"
            rows="6" maxlength="3000" placeholder="Descreva sua dúvida ou problema..." required></textarea>
        <div class="invalid-feedback">Escreva sua mensagem.</div>
        <div class="form-text text-end text-muted">
            <span id="charCount">0</span> / 3000 caracteres
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a href="/auth/login" class="btn btn-outline-secondary">
            <i class="fa-solid fa-xmark"></i> Cancelar
        </a>
        <button type="submit" class="btn btn-primary" id="btnEnviar">
            <i class="fa-solid fa-paper-plane"></i> Enviar
        </button>
    </div>

</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('contatoForm');
        const whatsappInput = document.getElementById('whatsapp');
        const emailInput = document.getElementById('email');
        const mensagemTextarea = document.getElementById('mensagem');
        const charCount = document.getElementById('charCount');
        const btnEnviar = document.getElementById('btnEnviar');

        // Normalização do WhatsApp — apenas dígitos
        whatsappInput.addEventListener('input', function () {
            const digits = String(whatsappInput.value || '').replace(/\D/g, '').slice(0, 11);
            if (whatsappInput.value !== digits) {
                whatsappInput.value = digits;
            }
        });

        // Normalização do e-mail
        emailInput.addEventListener('blur', function () {
            emailInput.value = String(emailInput.value || '').trim().toLowerCase();
        });

        // Contador de caracteres
        mensagemTextarea.addEventListener('input', function () {
            charCount.textContent = mensagemTextarea.value.length;
        });

        // Validação do formulário
        form.addEventListener('submit', function (e) {
            if (!form.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
            } else {
                btnEnviar.disabled = true;
                btnEnviar.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Enviando...';
            }
            form.classList.add('was-validated');
        });

        // Validação do arquivo — tamanho máximo 10 MB
        const arquivoInput = document.getElementById('arquivo');
        arquivoInput.addEventListener('change', function () {
            const file = arquivoInput.files[0];
            if (file && file.size > 10 * 1024 * 1024) {
                arquivoInput.value = '';
                alert('O arquivo selecionado excede o limite de 10 MB. Por favor, escolha um arquivo menor.');
            }
        });
    });
</script>
