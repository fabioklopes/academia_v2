<h1 class="mt-0 mb-2">Dashboard</h1>

{{#if metaProgress.hasMeta}}
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex flex-column gap-1">
                <div class="fw-semibold">Meta atual: {{metaProgress.metaTitle}}</div>
                <div class="small text-body-secondary">
                    Total de aulas: <span class="fw-semibold">{{metaProgress.totalClasses}}</span>
                    &nbsp;|&nbsp; Mínimo: <span class="fw-semibold">{{metaProgress.minClasses}}</span>
                    &nbsp;|&nbsp; Presenças: <span class="fw-semibold">{{metaProgress.presencasNaMeta}}</span>
                </div>
            </div>

            <div class="progress mt-3 meta-progress-track" style="height: 18px;" role="progressbar" aria-label="Progresso da meta">
                <div
                    id="metaProgressBar"
                    class="progress-bar meta-progress-bar"
                    style="width: 0%;"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-valuenow="{{metaProgress.percent}}"
                    data-target-percent="{{metaProgress.percent}}"
                >
                    {{metaProgress.percent}}%
                </div>
            </div>
        </div>
    </div>
{{/if}}

<style>
    .dashboard-card-link {
        color: inherit;
        text-decoration: none;
    }

    .dashboard-card {
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0.85rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        min-height: 170px;
        background-color: #ffffff;
    }

    .dashboard-card:hover,
    .dashboard-card:focus-within {
        transform: translateY(-4px);
        border-color: rgba(13, 110, 253, 0.6);
        box-shadow: 0 0.75rem 1.25rem rgba(0, 0, 0, 0.08);
        background-color: #f8fbff;
    }

    .dashboard-card-icon {
        font-size: 2rem;
        margin-bottom: 0.75rem;
    }

    @media (max-width: 767.98px) {
        .dashboard-card {
            min-height: auto;
        }
    }

    .meta-progress-track {
        background-color: rgba(13, 110, 253, 0.08);
        border-radius: 999px;
        overflow: hidden;
    }

    .meta-progress-bar {
        border-radius: 999px;
        transition: width 900ms ease;
        color: #fff;
        font-weight: 700;
        text-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const bar = document.getElementById('metaProgressBar');
        if (!bar) return;
        const target = parseInt(bar.getAttribute('data-target-percent') || '0', 10);
        const safe = Number.isFinite(target) ? Math.max(0, Math.min(100, target)) : 0;

        const colorClasses = ['bg-danger', 'bg-warning', 'bg-success', 'bg-primary'];
        colorClasses.forEach((c) => bar.classList.remove(c));
        if (safe <= 25) {
            bar.classList.add('bg-danger');
        } else if (safe <= 50) {
            bar.classList.add('bg-warning');
        } else if (safe <= 75) {
            bar.classList.add('bg-success');
        } else {
            bar.classList.add('bg-primary');
        }

        setTimeout(() => {
            bar.style.width = safe + '%';
        }, 50);
    });
</script>

<div class="row g-3 justify-content-center">
    <div class="col-6 col-md-3 d-flex">
        <a href="/presenca" class="dashboard-card-link w-100">
            <div class="card dashboard-card w-100 h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-calendar-check dashboard-card-icon text-primary"></i>
                    <h5 class="card-title mb-2">Minhas Presenças</h5>
                    {{#if metaProgress.hasMeta}}
                        <p class="card-text text-body-secondary mb-1 d-none d-md-block">
                            Aprovadas na meta atual: <span class="fw-semibold">{{metaProgress.presencasNaMeta}}</span>
                        </p>
                    {{/if}}
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Controle as suas presenças e registros de participação de aula.</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-md-3 d-flex">
        <a href="/metasdeaula" class="dashboard-card-link w-100">
            <div class="card dashboard-card w-100 h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-award dashboard-card-icon text-warning"></i>
                    <h5 class="card-title mb-2">Metas de aulas</h5>
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Defina objetivos e acompanhe evolução das turmas.</p>
                </div>
            </div>
        </a>
    </div>
</div>

{{> birthdayswidget birthdayWidget}}

{{#if motivationalMessage}}
    <p class="small text-secondary fst-italic text-center border rounded-2 px-3 py-2 mt-3 mb-0">"{{motivationalMessage}}"</p>
{{/if}}
