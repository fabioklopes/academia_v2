<h1 class="mt-0 mb-2">Dashboard</h1>

<style>
    .dashboard-card-link {
        color: inherit;
        text-decoration: none;
    }

    .dashboard-card {
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0.85rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        min-height: 170px;
        background-color: #ffffff;
    }

    .dashboard-card:hover,
    .dashboard-card:focus-within {
        transform: translateY(-4px);
        border-color: rgba(13, 110, 253, 0.6);
        box-shadow: 0 0.75rem 1.25rem rgba(0, 0, 0, 0.08);
        background-color: #f8fbff;
    }

    .dashboard-card-icon {
        font-size: 2rem;
        margin-bottom: 0.75rem;
    }

.dashboard-card-badge {
    position: absolute;
    top: 10px;
    right: 12px;
    min-width: 1.8rem;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    animation: pulseBadge 1.2s ease-in-out infinite;
}

@keyframes pulseBadge {
    0% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.6);
    }
    70% {
        transform: scale(1.08);
        box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
    }
    100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
    }
}

    @media (max-width: 767.98px) {
        .dashboard-card {
            min-height: auto;
        }
    }
</style>

<div class="row g-3 justify-content-center">
    <div class="col-6 col-md-3 d-flex">
        <a href="/presenca" class="dashboard-card-link w-100">
            <div class="card dashboard-card w-100 h-100 position-relative">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-calendar-check dashboard-card-icon text-primary"></i>
                    <h5 class="card-title mb-2">Gerenciar presenças</h5>
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Controle de frequência e registro de aulas.</p>
                    {{#if pendingPresencaCount}}
                        <span class="badge bg-danger text-white dashboard-card-badge" aria-label="{{pendingPresencaCount}} solicitações de presença pendentes">
                            {{pendingPresencaCount}}
                        </span>
                    {{/if}}
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-md-3 d-flex">
        <a href="/aluno" class="dashboard-card-link w-100">
            <div class="card dashboard-card w-100 h-100 position-relative">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-user-graduate dashboard-card-icon text-success"></i>
                    <h5 class="card-title mb-2">Gerenciar alunos</h5>
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Aprovações, edição de dados e acompanhamento.</p>
                    {{#if pendingStudentCount}}
                        <span class="badge bg-danger text-white dashboard-card-badge" aria-label="{{pendingStudentCount}} solicitações pendentes">
                            {{pendingStudentCount}}
                        </span>
                    {{/if}}
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-md-3 d-flex">
        <a href="/metasdeaula" class="dashboard-card-link w-100">
            <div class="card dashboard-card w-100 h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-award dashboard-card-icon text-warning"></i>
                    <h5 class="card-title mb-2">Metas de aulas</h5>
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Defina objetivos e acompanhe evolução das turmas.</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-md-3 d-flex">
        <a href="/relatorios" class="dashboard-card-link w-100" aria-disabled="true">
            <div class="card dashboard-card w-100 h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-chart-pie dashboard-card-icon text-info"></i>
                    <h5 class="card-title mb-2">Relatórios</h5>
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Visão estratégica de desempenho e indicadores.</p>
                </div>
            </div>
        </a>
    </div>
</div>

{{> birthdayswidget birthdayWidget}}

{{#if motivationalMessage}}
    <p class="small text-secondary fst-italic text-center border rounded-2 px-3 py-2 mt-3 mb-0">"{{motivationalMessage}}"</p>
{{/if}}
