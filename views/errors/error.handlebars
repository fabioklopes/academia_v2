<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5 text-center">
          <div class="mb-3">
            <i class="fa-solid {{iconClass}} fa-3x text-primary"></i>
          </div>

          <h1 class="h3 mb-2">{{title}}</h1>
          <div class="text-muted mb-3">
            <span class="badge text-bg-secondary">Erro {{statusCode}}</span>
          </div>

          {{#if message}}
            <p class="mb-4">{{message}}</p>
          {{else}}
            <p class="mb-4">Não foi possível concluir sua solicitação agora.</p>
          {{/if}}

          <a class="btn btn-primary px-4" href="/">
            <i class="fa-solid fa-house"></i> Voltar para o início
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

