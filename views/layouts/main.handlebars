        <!-- Modal calendário global: toggle-between-modals para todos os campos data -->
        <div class="modal fade" id="modalCalendario" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered" style="max-width:340px;">
                <div class="modal-content">
                    <div class="modal-header pb-2">
                        <h5 class="modal-title" id="modalCalendarioLabel">
                            <i class="fa-regular fa-calendar-days"></i> Selecionar data
                        </h5>
                        <button type="button" class="btn-close" id="btnCalendarioCancelar" aria-label="Cancelar"></button>
                    </div>
                    <div class="modal-body px-3 py-3">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="calBtnPrev" aria-label="Mês anterior">
                                <i class="fa-solid fa-chevron-left"></i>
                            </button>
                            <button type="button" id="calMonthYearLabel" class="btn btn-sm btn-light fw-semibold px-2" title="Clique para selecionar o ano"></button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="calBtnNext" aria-label="Próximo mês">
                                <i class="fa-solid fa-chevron-right"></i>
                            </button>
                        </div>
                        <div id="calGrid" class="cal-grid"></div>
                    </div>
                    <div class="modal-footer pt-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnCalendarioCancelarFooter">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>

        <script src="/js/popper.min.js" defer></script>
        <script src="/js/bootstrap.min.js" defer></script>
        <script src="/js/auto-dismiss.js" defer></script>
        <script>
            document.addEventListener('hide.bs.modal', function(event) {
                const focused = event.target.querySelector(':focus');
                if (focused) focused.blur();
            });
        </script>
        <script>
            (function initCalendarModal() {
                // ── Utilitários de formato ────────────────────────────────────────────────
                function pad2(n) { return String(Math.max(0, n)).padStart(2, '0'); }

                function formatISO(d) {
                    if (!(d instanceof Date) || isNaN(d)) return '';
                    return d.getFullYear() + '-' + pad2(d.getMonth() + 1) + '-' + pad2(d.getDate());
                }
                function parseISO(v) {
                    var m = String(v || '').trim().match(/^(\d{4})-(\d{2})-(\d{2})$/);
                    if (!m) return null;
                    var y = +m[1], mo = +m[2], da = +m[3];
                    if (!y || mo < 1 || mo > 12 || da < 1 || da > 31) return null;
                    var dt = new Date(y, mo - 1, da);
                    return (!isNaN(dt) && dt.getFullYear() === y && dt.getMonth() + 1 === mo && dt.getDate() === da) ? dt : null;
                }
                function formatBR(d) {
                    if (!(d instanceof Date) || isNaN(d)) return '';
                    return pad2(d.getDate()) + '/' + pad2(d.getMonth() + 1) + '/' + d.getFullYear();
                }
                function parseBR(v) {
                    var m = String(v || '').trim().match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
                    if (!m) return null;
                    var da = +m[1], mo = +m[2], y = +m[3];
                    if (!y || mo < 1 || mo > 12 || da < 1 || da > 31) return null;
                    var dt = new Date(y, mo - 1, da);
                    return (!isNaN(dt) && dt.getFullYear() === y && dt.getMonth() + 1 === mo && dt.getDate() === da) ? dt : null;
                }

                // ── Estado do calendário ──────────────────────────────────────────────────
                var _calModalBs = null;
                var _calState = null;       // { targetInput, parentModalEl, format }
                var _calViewYear = 0;
                var _calViewMonth = 0;
                var _calSelectedDate = null;
                var _calNavBound = false;
                var _calView = 'month';       // 'month' | 'year'
                var _calYearRangeStart = 0;   // primeiro ano da grade de anos

                var CAL_MONTHS = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                                  'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
                var CAL_DAYS   = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

                function calEl() { return document.getElementById('modalCalendario'); }

                function calBs() {
                    if (!_calModalBs) {
                        var el = calEl();
                        if (el && typeof bootstrap !== 'undefined') {
                            _calModalBs = new bootstrap.Modal(el, { backdrop: 'static', keyboard: false });
                        }
                    }
                    return _calModalBs;
                }

                // ── Renderização do calendário ────────────────────────────────────────────
                function renderCal(year, month, selectedDate) {
                    _calView = 'month';
                    _calViewYear = year;
                    _calViewMonth = month;
                    _calSelectedDate = selectedDate || null;

                    var grid = document.getElementById('calGrid');
                    if (!grid) return;
                    grid.style.gridTemplateColumns = '';
                    grid.innerHTML = '';

                    var lbl = document.getElementById('calMonthYearLabel');
                    if (lbl) lbl.textContent = CAL_MONTHS[month] + ' ' + year;

                    CAL_DAYS.forEach(function(d) {
                        var cell = document.createElement('div');
                        cell.className = 'cal-day-header';
                        cell.textContent = d;
                        grid.appendChild(cell);
                    });

                    var firstDay    = new Date(year, month, 1).getDay();
                    var daysInMonth = new Date(year, month + 1, 0).getDate();
                    var today       = new Date();
                    var todayY = today.getFullYear(), todayM = today.getMonth(), todayD = today.getDate();
                    var selY = selectedDate ? selectedDate.getFullYear() : null;
                    var selM = selectedDate ? selectedDate.getMonth()    : null;
                    var selD = selectedDate ? selectedDate.getDate()     : null;

                    for (var i = 0; i < firstDay; i++) {
                        grid.appendChild(document.createElement('div'));
                    }

                    for (var d = 1; d <= daysInMonth; d++) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.textContent = d;
                        btn.className = 'cal-day-btn';

                        var isToday = (year === todayY && month === todayM && d === todayD);
                        var isSel   = (selY !== null && year === selY && month === selM && d === selD);

                        if (isSel)        btn.classList.add('is-selected');
                        else if (isToday) btn.classList.add('is-today');

                        (function(day) {
                            btn.addEventListener('click', function() {
                                closeCalModal(new Date(year, month, day));
                            });
                        })(d);

                        grid.appendChild(btn);
                    }
                }

                function renderYearView() {
                    _calView = 'year';

                    var grid = document.getElementById('calGrid');
                    if (!grid) return;
                    grid.style.gridTemplateColumns = 'repeat(4, 1fr)';
                    grid.innerHTML = '';

                    var lbl = document.getElementById('calMonthYearLabel');
                    if (lbl) lbl.textContent = _calYearRangeStart + ' – ' + (_calYearRangeStart + 11);

                    var selY        = _calSelectedDate ? _calSelectedDate.getFullYear() : null;
                    var currentYear = new Date().getFullYear();

                    for (var i = 0; i < 12; i++) {
                        var y = _calYearRangeStart + i;
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.textContent = y;
                        btn.className = 'cal-year-btn';

                        if (y === selY)        btn.classList.add('is-selected');
                        else if (y === currentYear) btn.classList.add('is-today');

                        (function(theYear) {
                            btn.addEventListener('click', function() {
                                renderCal(theYear, _calViewMonth, _calSelectedDate);
                            });
                        })(y);

                        grid.appendChild(btn);
                    }
                }

                function bindCalNav() {
                    if (_calNavBound) return;
                    _calNavBound = true;

                    var prev = document.getElementById('calBtnPrev');
                    var next = document.getElementById('calBtnNext');
                    var lbl  = document.getElementById('calMonthYearLabel');

                    if (prev) prev.addEventListener('click', function() {
                        if (_calView === 'year') {
                            _calYearRangeStart -= 12;
                            renderYearView();
                        } else {
                            var m = _calViewMonth - 1, y = _calViewYear;
                            if (m < 0) { m = 11; y--; }
                            renderCal(y, m, _calSelectedDate);
                        }
                    });

                    if (next) next.addEventListener('click', function() {
                        if (_calView === 'year') {
                            _calYearRangeStart += 12;
                            renderYearView();
                        } else {
                            var m = _calViewMonth + 1, y = _calViewYear;
                            if (m > 11) { m = 0; y++; }
                            renderCal(y, m, _calSelectedDate);
                        }
                    });

                    if (lbl) lbl.addEventListener('click', function() {
                        if (_calView === 'month') {
                            _calYearRangeStart = _calViewYear - 5;
                            renderYearView();
                        } else {
                            renderCal(_calViewYear, _calViewMonth, _calSelectedDate);
                        }
                    });

                    ['btnCalendarioCancelar', 'btnCalendarioCancelarFooter'].forEach(function(id) {
                        var btn = document.getElementById(id);
                        if (btn) btn.addEventListener('click', function() { closeCalModal(null); });
                    });
                }

                // ── Abrir / fechar o modal calendário ────────────────────────────────────
                function openCalModal(targetInput, parentModalEl, format, labelText) {
                    bindCalNav();

                    _calState = { targetInput: targetInput, parentModalEl: parentModalEl, format: format };

                    var titleEl = document.getElementById('modalCalendarioLabel');
                    if (titleEl) {
                        titleEl.innerHTML = '<i class="fa-regular fa-calendar-days"></i> ' + (labelText || 'Selecionar data');
                    }

                    function show() {
                        var cur = format === 'br' ? parseBR(targetInput.value) : parseISO(targetInput.value);
                        var ref = cur || new Date();
                        renderCal(ref.getFullYear(), ref.getMonth(), cur || null);
                        var bs = calBs();
                        if (bs) bs.show();
                    }

                    if (parentModalEl) {
                        var parentBs = typeof bootstrap !== 'undefined'
                            ? bootstrap.Modal.getInstance(parentModalEl)
                            : null;
                        if (parentBs) {
                            parentModalEl.dataset.calReturning = '1';
                            parentModalEl.addEventListener('hidden.bs.modal', function h() {
                                parentModalEl.removeEventListener('hidden.bs.modal', h);
                                show();
                            });
                            parentBs.hide();
                            return;
                        }
                    }
                    show();
                }

                function closeCalModal(selectedDate) {
                    var state = _calState;
                    _calState = null;

                    if (state && selectedDate) {
                        var fmt = state.format === 'br' ? formatBR : formatISO;
                        state.targetInput.value = fmt(selectedDate);
                        state.targetInput.dispatchEvent(new Event('input',  { bubbles: true }));
                        state.targetInput.dispatchEvent(new Event('change', { bubbles: true }));
                    }

                    var modal = calBs();
                    var el    = calEl();

                    if (modal) {
                        if (state && state.parentModalEl) {
                            var parentEl = state.parentModalEl;
                            el.addEventListener('hidden.bs.modal', function h() {
                                el.removeEventListener('hidden.bs.modal', h);
                                bootstrap.Modal.getOrCreateInstance(parentEl).show();
                                parentEl.addEventListener('shown.bs.modal', function h2() {
                                    parentEl.removeEventListener('shown.bs.modal', h2);
                                    delete parentEl.dataset.calReturning;
                                });
                            });
                        }
                        modal.hide();
                    }
                }

                // Valida campos obrigatórios (readonly não participa da validação nativa do browser)
                document.addEventListener('submit', function(e) {
                    var inputs = e.target.querySelectorAll('[data-datepicker-bound="1"]');
                    for (var i = 0; i < inputs.length; i++) {
                        if (inputs[i].required && !inputs[i].value.trim()) {
                            e.preventDefault();
                            e.stopImmediatePropagation();
                            inputs[i].dispatchEvent(new Event('click', { bubbles: true }));
                            return;
                        }
                    }
                }, true);

                // ── Binding dos inputs de data ────────────────────────────────────────────
                function getInputLabel(inputEl) {
                    var wrap = inputEl.closest('.mb-3, .col-md-6, .col-12, .col-lg-6');
                    var lbl  = wrap ? wrap.querySelector('label') : null;
                    return lbl ? lbl.textContent.trim() : 'Selecionar data';
                }

                function bindDateInput(inputEl, mode) {
                    if (!inputEl || inputEl.dataset.datepickerBound === '1') return;
                    if (inputEl.readOnly || inputEl.disabled) return;

                    inputEl.dataset.datepickerBound = '1';
                    inputEl.readOnly = true;

                    var parentModal = inputEl.closest('.modal');
                    var label = getInputLabel(inputEl);

                    function open() { openCalModal(inputEl, parentModal, mode, label); }
                    inputEl.addEventListener('click', open);
                    inputEl.addEventListener('focus', function() { inputEl.blur(); open(); });
                }

                function bindAll() {
                    document.querySelectorAll('#birth_date, #rangeStart, #rangeEnd').forEach(function(el) {
                        bindDateInput(el, 'iso');
                    });
                    document.querySelectorAll('.meta-date-input').forEach(function(el) {
                        bindDateInput(el, 'br');
                    });
                }

                function schedule() {
                    setTimeout(function() {
                        requestAnimationFrame(function() { requestAnimationFrame(bindAll); });
                    }, 0);
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', schedule);
                } else {
                    schedule();
                }

                window.addEventListener('load', function() { requestAnimationFrame(bindAll); });

                if (typeof MutationObserver !== 'undefined') {
                    var moTimer = null;
                    var mo = new MutationObserver(function() {
                        clearTimeout(moTimer);
                        moTimer = setTimeout(bindAll, 50);
                    });
                    mo.observe(document.documentElement, { childList: true, subtree: true });
                }
            })();
        </script>
        <script>
            (function syncLayoutChromeHeights() {
                function compute() {
                    const header = document.getElementById('appHeaderNav');
                    const footer = document.getElementById('appFooter');
                    const headerHeight = header ? header.getBoundingClientRect().height : 0;
                    const footerHeight = footer ? footer.getBoundingClientRect().height : 0;
                    document.documentElement.style.setProperty('--app-header-height', `${Math.max(0, Math.round(headerHeight))}px`);
                    document.documentElement.style.setProperty('--app-footer-height', `${Math.max(0, Math.round(footerHeight))}px`);
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', compute);
                } else {
                    compute();
                }
                window.addEventListener('resize', compute);
            })();
        </script>
        <script>
            function isAppNavDrawerOpen() {
                const drawer = document.getElementById('appNavDrawer');
                return !!(drawer && drawer.classList.contains('show'));
            }

            function updateStudentMassMessageBell(massUnreadCount) {
                const bellLink = document.getElementById('studentMassMessageBellLink');
                const bellIcon = document.getElementById('studentMassMessageBellIcon');
                const bellBadge = document.getElementById('studentMassMessageBellBadge');
                const massMenuBadge = document.getElementById('studentMassMessageMenuBadge');
                const notifMenuBadge = document.getElementById('studentNotificationsMenuBadge');

                if (!bellLink || !bellIcon || !bellBadge) {
                    return;
                }

                const mass = Math.max(Number(massUnreadCount) || 0, 0);
                const notif = Math.max(parseInt(bellLink.getAttribute('data-notif-unread') || '0', 10) || 0, 0);
                const navbarTotal = mass + notif;
                const hasNavbarUnread = navbarTotal > 0;
                const drawerOpen = isAppNavDrawerOpen();

                bellLink.setAttribute('data-mass-unread', String(mass));
                bellLink.classList.toggle('is-idle', !hasNavbarUnread);
                bellIcon.innerHTML = hasNavbarUnread
                    ? '<i class="fa-solid fa-bell fa-shake text-primary"></i>'
                    : '<i class="fa-solid fa-bell text-secondary"></i>';

                bellBadge.textContent = String(navbarTotal);
                bellBadge.classList.toggle('d-none', drawerOpen || !hasNavbarUnread);

                if (massMenuBadge) {
                    massMenuBadge.textContent = String(mass);
                    massMenuBadge.classList.toggle('d-none', !drawerOpen || mass === 0);
                }

                if (notifMenuBadge) {
                    notifMenuBadge.textContent = String(notif);
                    notifMenuBadge.classList.toggle('d-none', !drawerOpen || notif === 0);
                }
            }

            function bindAppNavDrawerBellSync() {
                const drawer = document.getElementById('appNavDrawer');
                if (!drawer) {
                    return;
                }

                const syncFromDrawer = function () {
                    const bellLink = document.getElementById('studentMassMessageBellLink');
                    const mass = bellLink
                        ? Math.max(parseInt(bellLink.getAttribute('data-mass-unread') || '0', 10) || 0, 0)
                        : 0;
                    updateStudentMassMessageBell(mass);
                };

                drawer.addEventListener('shown.bs.offcanvas', syncFromDrawer);
                drawer.addEventListener('hidden.bs.offcanvas', syncFromDrawer);
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', bindAppNavDrawerBellSync);
            } else {
                bindAppNavDrawerBellSync();
            }
        </script>
        {{#if birthdayLoginModal}}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const modalElement = document.getElementById('birthdayLoginModal');
                if (!modalElement || typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                    return;
                }

                const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
                const closeButton = document.getElementById('birthdayLoginModalCloseButton');
                const checkbox = document.getElementById('birthdayDisableMessagesCheckbox');

                modalInstance.show();

                if (!closeButton) {
                    return;
                }

                closeButton.addEventListener('click', async function() {
                    closeButton.disabled = true;

                    try {
                        if (checkbox && checkbox.checked) {
                            await fetch('/aniversario/mensagens/desativar', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ disable: true })
                            });
                        }
                    } catch (error) {
                        console.error('Erro ao salvar preferência de aniversário:', error);
                    } finally {
                        modalInstance.hide();
                        closeButton.disabled = false;
                    }
                });
            });
        </script>
        {{/if}}

    </body>

</html>