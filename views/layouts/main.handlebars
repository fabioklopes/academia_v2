<!doctype html>
<html lang="pt-BR">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="mobile-web-app-capable" content="yes">
        
        <title>Sistema Oss - Gestão de Jiu-jitsu</title>

        <link href="/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
        <link rel="stylesheet" href="https://unpkg.com/js-datepicker/dist/datepicker.min.css">
        <link rel="icon" href="/img/logotipo.ico">
        <style>
            :root {
                --app-header-height: 0px;
                --app-footer-height: 0px;
            }

            /* js-datepicker (mobile-first): não pode estourar a tela nem o layout */
            .qs-datepicker-container {
                z-index: 2000; /* acima de navbar/modais */
                max-width: min(22rem, calc(100vw - 1rem));
                width: auto;
            }

            .qs-datepicker {
                width: 100%;
                max-width: 100%;
            }

            .qs-datepicker .qs-controls {
                padding: 0.4rem 0.5rem;
            }

            .qs-datepicker .qs-squares {
                width: 100%;
            }

            .qs-datepicker .qs-square {
                padding: 0.45rem 0;
            }

            @media (min-width: 576px) {
                .qs-datepicker-container {
                    max-width: min(24rem, calc(100vw - 2rem));
                }
            }

            /* Modais com static backdrop não devem “tomar” header/footer */
            .modal {
                padding-top: calc(var(--app-header-height) + 0.75rem);
                padding-bottom: calc(var(--app-footer-height) + 0.75rem);
            }

            .modal-dialog {
                margin-top: 0;
                margin-bottom: 0;
            }

            .modal-content {
                max-height: calc(100vh - var(--app-header-height) - var(--app-footer-height) - 1.5rem);
                overflow: hidden;
            }

            .modal-body {
                overflow: auto;
            }

            .student-message-bell-link {
                position: relative;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 2.5rem;
                height: 2.5rem;
                color: var(--bs-body-color);
                text-decoration: none;
            }

            .student-message-bell-link:hover {
                color: var(--bs-danger);
            }

            .student-message-bell-link.is-idle {
                color: var(--bs-secondary-color);
                opacity: 0.55;
            }

            .student-message-bell-icon {
                font-size: 1.25rem;
                line-height: 1;
            }

            .student-message-bell-badge {
                min-width: 1.2rem;
                font-size: 0.68rem;
            }

            .table-mobile-stack {
                width: 100%;
            }

            .table-mobile-stack td {
                overflow-wrap: anywhere;
            }

            @media (max-width: 768px) {
                .table-mobile-stack thead {
                    display: none;
                }

                .table-mobile-stack,
                .table-mobile-stack tbody,
                .table-mobile-stack tr,
                .table-mobile-stack td {
                    display: block;
                    width: 100%;
                }

                .table-mobile-stack tbody tr {
                    margin-bottom: 1rem;
                    border: 1px solid var(--bs-border-color);
                    border-radius: 0.75rem;
                    background-color: var(--bs-body-bg);
                    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
                    overflow: hidden;
                }

                .table-mobile-stack tbody td {
                    display: flex;
                    justify-content: space-between;
                    gap: 1rem;
                    padding: 0.75rem 1rem;
                    border: 0;
                    border-bottom: 1px solid var(--bs-border-color-translucent);
                    text-align: right;
                }

                .table-mobile-stack tbody td:last-child {
                    border-bottom: 0;
                }

                .table-mobile-stack tbody td::before {
                    content: attr(data-label);
                    font-weight: 600;
                    color: var(--bs-secondary-color);
                    text-align: left;
                    margin-right: 1rem;
                }
            }
        </style>

        <!-- Título do preview -->
        <meta property="og:title" content="CRTN Belém - Jiu-jitsu ADPM">

        <!-- Descrição do preview -->
        <meta property="og:description" content="Sistema gerenciador de alunos, turmas e controle de presenças">

        <!-- Imagem do preview -->
        <meta property="og:image" content="/img/logotipo.ico">

        <!-- URL da página -->
        <meta property="og:url" content="https://iliac-markita-nattily.ngrok-free.dev">

        <!-- Tipo de conteúdo -->
        <meta property="og:type" content="website">

    </head>

    <body>
        <div class="container p-1">
            <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom border-3 border-primary" id="appHeaderNav">
                <div class="container-fluid">

                    <a class="navbar-brand" href="/"><b>CRTN Belém</b></a>

                    {{#if studentMassMessageBell}}
                    <a
                        class="student-message-bell-link ms-auto me-2 {{#unless studentMassMessageBell.hasUnread}}is-idle{{/unless}}"
                        id="studentMassMessageBellLink"
                        href="{{studentMassMessageBell.href}}"
                        aria-label="Mensagens do Mestre"
                        title="Mensagens do Mestre"
                    >
                        <span class="student-message-bell-icon" id="studentMassMessageBellIcon">
                            <i class="fa-solid fa-bell{{#if studentMassMessageBell.hasUnread}} fa-shake text-primary{{else}} text-secondary{{/if}}"></i>
                        </span>
                        <span class="badge rounded-pill text-bg-danger position-absolute top-0 start-50 translate-middle student-message-bell-badge {{#unless studentMassMessageBell.hasUnread}}d-none{{/unless}}" id="studentMassMessageBellBadge">{{studentMassMessageBell.unreadCount}}</span>
                    </a>
                    {{/if}}

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav w-100">

                            <!-- usuário logado -->
                            {{#if usuarioLogado}}
                            <li class="nav-item">
                                <span class="nav-link disabled">
                                    {{#if viewingAs}}
                                    <i class="fa-solid fa-child"></i> {{viewingAs.first_name}} {{viewingAs.last_name}}
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item text-info" href="/conta/voltar">
                                    <i class="fa-solid fa-arrow-left"></i> Voltar para minha conta
                                </a>
                            </li>
                            {{else}}
                            <i class="fa-solid fa-user"></i>
                            {{usuarioLogado.first_name}} {{usuarioLogado.last_name}}
                            {{/if}}

                            </span>
                            </li>
                            {{/if}}

                            {{#if usuarioLogado}}
                            <li class="nav-item">
                                <span class="nav-link text-uppercase">
                                    <i class="fa-solid fa-square-binary"></i> Código: {{usuarioLogado.user_code}}
                                </span>
                            </li>
                            {{/if}}

                            <!-- Início conforme nível de acesso -->
                            <li class="nav-item">
                                <a class="nav-link" href="/dashboard">
                                    <i class="fa-solid fa-star"></i> INÍCIO
                                </a>
                            </li>

                            {{#if usuarioLogado}}
                            {{#if useProfessorMenu}}
                            {{> menuprofessor}}
                            {{else}}
                            {{> menualuno}}
                            {{/if}}
                            {{/if}}
                        </ul>
                    </div>
                </div>
            </nav>
        </div>

        <div class="container p-2">
            <div class="mt-3 mb-1">
                {{{body}}}
            </div>
        </div>

        {{#if birthdayLoginModal}}
        <div class="modal fade" id="birthdayLoginModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">{{birthdayLoginModal.title}}</h5>
                    </div>
                    <div class="modal-body text-center">
                        {{{birthdayLoginModal.bodyHtml}}}
                    </div>
                    <div class="modal-footer justify-content-start align-items-start flex-column flex-sm-row gap-2">
                        <div class="form-check m-0">
                            <input class="form-check-input" type="checkbox" value="1" id="birthdayDisableMessagesCheckbox">
                            <label class="form-check-label" for="birthdayDisableMessagesCheckbox">
                                {{birthdayLoginModal.checkboxLabel}}
                            </label>
                        </div>
                        <button type="button" class="btn btn-primary px-4" id="birthdayLoginModalCloseButton">Fechar</button>
                    </div>
                </div>
            </div>
        </div>
        {{/if}}

        <script src="https://unpkg.com/js-datepicker/dist/datepicker.min.js"></script>
        <script src="/js/popper.min.js" defer></script>
        <script src="/js/bootstrap.min.js" defer></script>
        <script src="/js/auto-dismiss.js" defer></script>
        <script>
            (function initAppDatepickers() {
                const DATEPICKER_PT_BR = {
                    customDays: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'],
                    customMonths: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                    overlayPlaceholder: 'Digite o ano',
                    overlayButton: 'Ir',
                    startDay: 0, // domingo
                };

                function pad2(n) {
                    return String(Math.max(0, n)).padStart(2, '0');
                }

                function formatISO(d) {
                    if (!(d instanceof Date) || Number.isNaN(d.getTime())) return '';
                    return `${d.getFullYear()}-${pad2(d.getMonth() + 1)}-${pad2(d.getDate())}`;
                }

                function parseISO(value) {
                    const v = String(value || '').trim();
                    const m = v.match(/^(\d{4})-(\d{2})-(\d{2})$/);
                    if (!m) return null;
                    const y = Number(m[1]);
                    const mo = Number(m[2]);
                    const da = Number(m[3]);
                    if (!y || mo < 1 || mo > 12 || da < 1 || da > 31) return null;
                    const dt = new Date(y, mo - 1, da);
                    if (Number.isNaN(dt.getTime())) return null;
                    if (dt.getFullYear() !== y || (dt.getMonth() + 1) !== mo || dt.getDate() !== da) return null;
                    return dt;
                }

                function formatBR(d) {
                    if (!(d instanceof Date) || Number.isNaN(d.getTime())) return '';
                    return `${pad2(d.getDate())}/${pad2(d.getMonth() + 1)}/${d.getFullYear()}`;
                }

                function parseBR(value) {
                    const v = String(value || '').trim();
                    const m = v.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
                    if (!m) return null;
                    const da = Number(m[1]);
                    const mo = Number(m[2]);
                    const y = Number(m[3]);
                    if (!y || mo < 1 || mo > 12 || da < 1 || da > 31) return null;
                    const dt = new Date(y, mo - 1, da);
                    if (Number.isNaN(dt.getTime())) return null;
                    if (dt.getFullYear() !== y || (dt.getMonth() + 1) !== mo || dt.getDate() !== da) return null;
                    return dt;
                }

                function getViewportInsets() {
                    const styles = getComputedStyle(document.documentElement);
                    const header = parseInt(styles.getPropertyValue('--app-header-height') || '0', 10) || 0;
                    const footer = parseInt(styles.getPropertyValue('--app-footer-height') || '0', 10) || 0;
                    return { top: Math.max(0, header), bottom: Math.max(0, footer) };
                }

                function clampDatepickerContainer(container) {
                    if (!container) return;
                    const rect = container.getBoundingClientRect();
                    const pad = 8;
                    const insets = getViewportInsets();

                    const maxLeft = Math.max(pad, window.innerWidth - pad - rect.width);
                    const minLeft = pad;
                    const maxTop = Math.max(pad + insets.top, window.innerHeight - pad - insets.bottom - rect.height);
                    const minTop = pad + insets.top;

                    const desiredLeft = Math.min(Math.max(rect.left, minLeft), maxLeft);
                    const desiredTop = Math.min(Math.max(rect.top, minTop), maxTop);

                    const cs = getComputedStyle(container);
                    const pos = cs.position;
                    const dx = desiredLeft - rect.left;
                    const dy = desiredTop - rect.top;
                    if (Math.abs(dx) < 0.5 && Math.abs(dy) < 0.5) return;

                    if (pos === 'fixed') {
                        container.style.left = `${(rect.left + dx)}px`;
                        container.style.top = `${(rect.top + dy)}px`;
                    } else {
                        container.style.left = `${(rect.left + dx + window.scrollX)}px`;
                        container.style.top = `${(rect.top + dy + window.scrollY)}px`;
                    }

                    container.style.maxWidth = `min(24rem, calc(100vw - ${pad * 2}px))`;
                    container.style.maxHeight = `calc(100vh - ${insets.top + insets.bottom + pad * 2}px)`;
                }

                function clampLatestDatepickerSoon() {
                    window.setTimeout(() => {
                        const containers = Array.from(document.querySelectorAll('.qs-datepicker-container'));
                        const latest = containers[containers.length - 1];
                        clampDatepickerContainer(latest);
                    }, 0);
                }

                function attachDatepickerToInput(inputEl, mode) {
                    if (!inputEl || inputEl.dataset.datepickerBound === '1') return;
                    if (inputEl.readOnly || inputEl.disabled) return;

                    inputEl.dataset.datepickerBound = '1';

                    const isBR = mode === 'br';
                    const parser = isBR ? parseBR : parseISO;
                    const formatter = isBR
                        ? (input, date) => { input.value = formatBR(date); }
                        : (input, date) => { input.value = formatISO(date); };

                    datepicker(inputEl, {
                        ...DATEPICKER_PT_BR,
                        formatter,
                        parser: (str) => parser(str),
                        onShow: clampLatestDatepickerSoon,
                        onSelect: clampLatestDatepickerSoon,
                        position: 'bl',
                    });

                    inputEl.addEventListener('focus', clampLatestDatepickerSoon);
                    inputEl.addEventListener('click', clampLatestDatepickerSoon);
                }

                function init() {
                    if (typeof datepicker !== 'function') return;

                    // ISO (aaaa-mm-dd): inputs que antes eram type="date"
                    document.querySelectorAll('#birth_date, #rangeStart, #rangeEnd').forEach((el) => {
                        attachDatepickerToInput(el, 'iso');
                    });

                    // BR (dd/mm/aaaa): metas
                    document.querySelectorAll('.meta-date-input').forEach((el) => {
                        attachDatepickerToInput(el, 'br');
                    });

                    window.addEventListener('resize', clampLatestDatepickerSoon);
                    window.addEventListener('scroll', clampLatestDatepickerSoon, true);
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', init);
                } else {
                    init();
                }
            })();
        </script>
        <script>
            (function syncLayoutChromeHeights() {
                function compute() {
                    const header = document.getElementById('appHeaderNav');
                    const footer = document.getElementById('appFooter');
                    const headerHeight = header ? header.getBoundingClientRect().height : 0;
                    const footerHeight = footer ? footer.getBoundingClientRect().height : 0;
                    document.documentElement.style.setProperty('--app-header-height', `${Math.max(0, Math.round(headerHeight))}px`);
                    document.documentElement.style.setProperty('--app-footer-height', `${Math.max(0, Math.round(footerHeight))}px`);
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', compute);
                } else {
                    compute();
                }
                window.addEventListener('resize', compute);
            })();
        </script>
        <script>
            function updateStudentMassMessageBell(unreadCount) {
                const bellLink = document.getElementById('studentMassMessageBellLink');
                const bellIcon = document.getElementById('studentMassMessageBellIcon');
                const bellBadge = document.getElementById('studentMassMessageBellBadge');
                const menuBadge = document.getElementById('studentMassMessageMenuBadge');

                if (!bellLink || !bellIcon || !bellBadge) {
                    return;
                }

                const normalizedUnreadCount = Math.max(Number(unreadCount) || 0, 0);
                const hasUnread = normalizedUnreadCount > 0;

                bellLink.classList.toggle('is-idle', !hasUnread);
                bellIcon.innerHTML = hasUnread
                    ? '<i class="fa-solid fa-bell fa-shake text-primary"></i>'
                    : '<i class="fa-solid fa-bell text-secondary"></i>';

                bellBadge.textContent = String(normalizedUnreadCount);
                bellBadge.classList.toggle('d-none', !hasUnread);

                if (menuBadge) {
                    menuBadge.textContent = String(normalizedUnreadCount);
                    menuBadge.classList.toggle('d-none', !hasUnread);
                }
            }
        </script>
        {{#if birthdayLoginModal}}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const modalElement = document.getElementById('birthdayLoginModal');
                if (!modalElement || typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                    return;
                }

                const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
                const closeButton = document.getElementById('birthdayLoginModalCloseButton');
                const checkbox = document.getElementById('birthdayDisableMessagesCheckbox');

                modalInstance.show();

                if (!closeButton) {
                    return;
                }

                closeButton.addEventListener('click', async function() {
                    closeButton.disabled = true;

                    try {
                        if (checkbox && checkbox.checked) {
                            await fetch('/aniversario/mensagens/desativar', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ disable: true })
                            });
                        }
                    } catch (error) {
                        console.error('Erro ao salvar preferência de aniversário:', error);
                    } finally {
                        modalInstance.hide();
                        closeButton.disabled = false;
                    }
                });
            });
        </script>
        {{/if}}

    </body>

</html>