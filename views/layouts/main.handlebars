<!doctype html>
<html lang="pt-BR">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="mobile-web-app-capable" content="yes">
        
        <title>{{#if metaTitle}}{{metaTitle}}{{else}}Sistema Oss - Gestão de Jiu-jitsu{{/if}}</title>
        <meta name="description" content="{{#if metaDescription}}{{metaDescription}}{{else}}Sistema gerenciador de alunos, turmas e controle de presenças{{/if}}">
        <link rel="canonical" href="{{#if metaUrl}}{{metaUrl}}{{else}}https://iliac-markita-nattily.ngrok-free.dev{{/if}}">
        <meta name="robots" content="{{#if metaRobots}}{{metaRobots}}{{else}}index,follow{{/if}}">

        <link href="/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
        <link rel="icon" href="/img/logotipo.ico">
        <style>
            :root {
                --app-header-height: 0px;
                --app-footer-height: 0px;
            }

            /* Calendário customizado no modal de seleção de data */
            .cal-grid {
                display: grid;
                grid-template-columns: repeat(7, 1fr);
                gap: 2px;
                text-align: center;
            }

            .cal-day-header {
                font-size: 0.72rem;
                font-weight: 600;
                color: var(--bs-secondary-color);
                padding: 4px 0;
            }

            .cal-day-btn {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                border: none;
                background: transparent;
                font-size: 0.875rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: auto;
                padding: 0;
                transition: background-color 0.1s;
                color: var(--bs-body-color);
            }

            .cal-day-btn:hover:not(.is-selected) {
                background-color: var(--bs-secondary-bg);
            }

            .cal-day-btn.is-today {
                border: 2px solid var(--bs-primary);
                color: var(--bs-primary);
                font-weight: 600;
            }

            .cal-day-btn.is-selected {
                background-color: var(--bs-primary);
                color: #fff;
                font-weight: 600;
            }

            /* Botões de ano (grade 4 colunas) */
            .cal-year-btn {
                min-width: 56px;
                height: 36px;
                border-radius: 18px;
                border: none;
                background: transparent;
                font-size: 0.875rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: auto;
                padding: 0 6px;
                transition: background-color 0.1s;
                color: var(--bs-body-color);
            }

            .cal-year-btn:hover:not(.is-selected) {
                background-color: var(--bs-secondary-bg);
            }

            .cal-year-btn.is-today {
                border: 2px solid var(--bs-primary);
                color: var(--bs-primary);
                font-weight: 600;
            }

            .cal-year-btn.is-selected {
                background-color: var(--bs-primary);
                color: #fff;
                font-weight: 600;
            }

            /* Campos data gerenciados pelo modal calendário: aparência editável mesmo com readonly */
            input[data-datepicker-bound="1"].form-control,
            input[data-datepicker-bound="1"].form-control:focus {
                background-color: var(--bs-body-bg) !important;
                cursor: pointer !important;
                color: var(--bs-body-color) !important;
            }

            /* Modais com static backdrop não devem “tomar” header/footer */
            .modal {
                padding-top: calc(var(--app-header-height) + 0.75rem);
                padding-bottom: calc(var(--app-footer-height) + 0.75rem);
            }

            .modal-dialog {
                margin-top: 0;
                margin-bottom: 0;
            }

            .modal-content {
                max-height: calc(100vh - var(--app-header-height) - var(--app-footer-height) - 1.5rem);
                overflow: hidden;
            }

            .modal-body {
                overflow: auto;
            }

            .student-message-bell-link {
                position: relative;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 2.5rem;
                height: 2.5rem;
                color: var(--bs-body-color);
                text-decoration: none;
            }

            .student-message-bell-link:hover {
                color: var(--bs-danger);
            }

            .student-message-bell-link.is-idle {
                color: var(--bs-secondary-color);
                opacity: 0.55;
            }

            .student-message-bell-icon {
                font-size: 1.25rem;
                line-height: 1;
            }

            .student-message-bell-badge {
                min-width: 1.2rem;
                font-size: 0.68rem;
            }

            #appNavDrawer .offcanvas-body {
                overflow-y: auto;
            }

            #appNavDrawer .nav-link {
                padding-left: 1rem;
                padding-right: 1rem;
            }

            .app-nav-drawer-badge {
                min-width: 1.35rem;
            }

            .table-mobile-stack {
                width: 100%;
            }

            .table-mobile-stack td {
                overflow-wrap: anywhere;
            }

            @media (max-width: 768px) {
                .table-mobile-stack thead {
                    display: none;
                }

                .table-mobile-stack,
                .table-mobile-stack tbody,
                .table-mobile-stack tr,
                .table-mobile-stack td {
                    display: block;
                    width: 100%;
                }

                .table-mobile-stack tbody tr {
                    margin-bottom: 1rem;
                    border: 1px solid var(--bs-border-color);
                    border-radius: 0.75rem;
                    background-color: var(--bs-body-bg);
                    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
                    overflow: hidden;
                }

                .table-mobile-stack tbody td {
                    display: flex;
                    justify-content: space-between;
                    gap: 1rem;
                    padding: 0.75rem 1rem;
                    border: 0;
                    border-bottom: 1px solid var(--bs-border-color-translucent);
                    text-align: right;
                }

                .table-mobile-stack tbody td:last-child {
                    border-bottom: 0;
                }

                .table-mobile-stack tbody td::before {
                    content: attr(data-label);
                    font-weight: 600;
                    color: var(--bs-secondary-color);
                    text-align: left;
                    margin-right: 1rem;
                }
            }
        </style>

        <!-- Título do preview -->
        <meta property="og:title" content="{{#if metaTitle}}{{metaTitle}}{{else}}CRTN Belém - Jiu-jitsu ADPM{{/if}}">

        <!-- Descrição do preview -->
        <meta property="og:description" content="{{#if metaDescription}}{{metaDescription}}{{else}}Sistema gerenciador de alunos, turmas e controle de presenças{{/if}}">

        <!-- Imagem do preview -->
        <meta property="og:image" content="{{#if metaImage}}{{metaImage}}{{else}}/img/logotipo.ico{{/if}}">

        <!-- URL da página -->
        <meta property="og:url" content="{{#if metaUrl}}{{metaUrl}}{{else}}https://iliac-markita-nattily.ngrok-free.dev{{/if}}">

        <!-- Tipo de conteúdo -->
        <meta property="og:type" content="{{#if metaType}}{{metaType}}{{else}}website{{/if}}">

    </head>

