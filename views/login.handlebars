<!doctype html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="description" content="Acesse o portal CRTN Belém para login de alunos e professores, controle de turmas e presenças.">
        <link rel="canonical" href="{{{protocol}}}://{{{host}}}/auth/login">
        <meta name="robots" content="index,follow">
        <meta property="og:title" content="CRTN Belém | Login do Portal de Alunos">
        <meta property="og:description" content="Acesse o portal CRTN Belém para login de alunos e professores, controle de turmas e presenças.">
        <meta property="og:image" content="/img/logotipo.ico">
        <meta property="og:url" content="{{{protocol}}}://{{{host}}}/auth/login">
        <meta property="og:type" content="website">
        <link href="/css/bootstrap.min.css" rel="stylesheet">
        <link rel="icon" href="/img/logotipo.ico">
        <title>CRTN Belém | Login</title>
    </head>

    <body>
        <div class="container mt-2 p-1 d-flex flex-column align-items-center" style="max-width: 400px;">
            <img src="/img/logotipo_transparente.png" alt="Logotipo CRTN" class="img-fluid mb-3" width="50">
            <h1 class="mb-3 fs-4 text-center">CRTN Belém - ADPM</h1>

            <div class="alert alert-success" role="alert">
                <a href="https://github.com/fabioklopes/academia_v2/releases/tag/release-2.0" class="link-success" target="_blank" rel="noopener noreferrer">
                    Leia as informações disponíveis na nova versão
                </a>
            </div>

            {{#if erro}}
            <div class="alert alert-danger alert-autodismiss" role="alert">{{erro}}</div>
            {{/if}}
            {{#if aviso}}
            <div class="alert alert-warning alert-autodismiss" role="alert">{{aviso}}</div>
            {{/if}}

            <form action="/auth/verify" method="POST" class="mb-3">
                <input type="hidden" name="redirect" value="{{redirect}}">
                <div class="mb-3">
                    <label for="email" class="form-label">E-mail</label>
                    <input type="email" class="form-control" id="email" name="email" autocomplete="email" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Senha</label>
                    <input type="password" class="form-control" id="password" name="password"
                        autocomplete="new-password" required>
                </div>

                <!-- Esqueci a senha | FAQ | Contato -->
                <div class="mb-3 text-center">
                    <a href="/auth/forgot-password" class="link-secondary">Esqueci minha senha</a>
                    <span class="text-muted mx-1">|</span>
                    <a href="/faq" class="link-secondary">FAQ</a>
                    <span class="text-muted mx-1">|</span>
                    <a href="/contato" class="link-secondary">Fale conosco</a>
                </div>

                <!-- Botões de acesso / solicitação de cesso -->
                <div class="d-flex justify-content-center gap-2">
                    <button type="submit" class="btn btn-outline-primary">Entrar</button>

                    <a href="/aluno/novo" class="btn btn-outline-secondary">Solicitar acesso</a>
                </div>

            </form>
        </div>

        <script src="/js/auto-dismiss.js" defer></script>
    </body>

</html>