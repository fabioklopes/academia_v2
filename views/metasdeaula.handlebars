<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h1 class="mb-0">Metas</h1>
    {{#if isProfessorPage}}
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNovaMetaAula">
        <i class="fa-solid fa-plus"></i> Nova meta
    </button>
    {{/if}}
</div>

{{#if mensagem}}
<div class="alert alert-{{tipoMensagem}} alert-autodismiss" role="alert">
    {{#if (eq tipoMensagem 'danger')}}<i class="fa-solid fa-circle-xmark"></i>{{else}}<i class="fa-solid fa-circle-check"></i>{{/if}} {{mensagem}}
</div>
{{/if}}

{{#if isProfessorPage}}
<div class="row g-3" id="metasCardsRow">
    {{#each metas}}
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 meta-card" role="button" tabindex="0"
             data-meta-id="{{id}}"
             data-meta-title="{{title}}"
             data-meta-description="{{description}}"
             data-meta-classes="{{classesLabel}}"
             data-meta-start-date="{{start_date}}"
             data-meta-end-date="{{end_date}}"
             data-meta-exam-start-date="{{exam_start_date}}"
             data-meta-exam-end-date="{{exam_end_date}}"
             data-meta-status="{{status}}"
             data-meta-status-label="{{statusLabel}}">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                    <h6 class="card-title mb-0">{{title}}</h6>
                    <span class="badge bg-{{#if (eq status 'A')}}success{{else}}secondary{{/if}}">{{statusLabel}}</span>
                </div>
                <div class="small text-body-secondary mb-2">
                    <i class="fa-solid fa-calendar-days"></i> {{start_date}} a {{end_date}}
                </div>
                <div class="small text-body-secondary">
                    <i class="fa-solid fa-users"></i> {{classesLabel}}
                </div>
            </div>
        </div>
    </div>
    {{/each}}
</div>

{{#unless metas.length}}
<div class="text-center py-5">
    <i class="fa-solid fa-award fa-3x text-body-secondary mb-3"></i>
    <p class="text-body-secondary mb-0">Nenhuma meta de aula criada ainda.</p>
</div>
{{/unless}}

<!-- Modal de Detalhes da Meta -->
<div class="modal fade" id="metaDetailModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="metaDetailTitle">Detalhes da Meta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge" id="metaDetailStatusBadge"></span>
                </div>

                <div class="mb-3">
                    <div class="small text-body-secondary mb-1">Descrição</div>
                    <div class="fs-6" id="metaDetailDescription"></div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="small text-body-secondary mb-1">Turmas</div>
                        <div class="fs-6" id="metaDetailClasses"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-body-secondary mb-1">Período</div>
                        <div class="fs-6" id="metaDetailPeriod"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-body-secondary mb-1">Período de Exame</div>
                        <div class="fs-6" id="metaDetailExamPeriod"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const metaCards = document.querySelectorAll('.meta-card');
    const detailModal = new bootstrap.Modal(document.getElementById('metaDetailModal'));
    const detailTitle = document.getElementById('metaDetailTitle');
    const detailStatusBadge = document.getElementById('metaDetailStatusBadge');
    const detailDescription = document.getElementById('metaDetailDescription');
    const detailClasses = document.getElementById('metaDetailClasses');
    const detailPeriod = document.getElementById('metaDetailPeriod');
    const detailExamPeriod = document.getElementById('metaDetailExamPeriod');

    metaCards.forEach(card => {
        card.addEventListener('click', function() {
            const title = this.dataset.metaTitle;
            const description = this.dataset.metaDescription;
            const classes = this.dataset.metaClasses;
            const startDate = this.dataset.metaStartDate;
            const endDate = this.dataset.metaEndDate;
            const examStartDate = this.dataset.metaExamStartDate;
            const examEndDate = this.dataset.metaExamEndDate;
            const status = this.dataset.metaStatus;
            const statusLabel = this.dataset.metaStatusLabel;

            detailTitle.textContent = title;
            detailDescription.textContent = description;
            detailClasses.textContent = classes;
            detailPeriod.textContent = `${startDate} a ${endDate}`;
            detailExamPeriod.textContent = `${examStartDate} à ${examEndDate}`;
            detailStatusBadge.textContent = statusLabel;
            detailStatusBadge.className = `badge bg-${status === 'A' ? 'success' : 'secondary'}`;

            detailModal.show();
        });

        card.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                this.click();
            }
        });
    });
});
</script>

<div class="modal fade" id="modalNovaMetaAula" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content">
            <form method="POST" action="/metasdeaula" id="formNovaMetaAula">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-solid fa-award"></i> Nova meta de aula</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cancelar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="metaTitle" class="form-label">Título da meta</label>
                        <input type="text" id="metaTitle" name="title" class="form-control" maxlength="50" required>
                        <div class="form-text">Máximo de 50 caracteres.</div>
                    </div>

                    <div class="mb-3">
                        <label for="metaDescription" class="form-label">Descrição da meta</label>
                        <textarea id="metaDescription" name="description" class="form-control" rows="4" required></textarea>
                    </div>

                    <div class="row gy-3 mb-3">
                        <div class="col-md-6">
                            <label for="metaTotalClasses" class="form-label">Quantidade total de aulas</label>
                            <input type="number" id="metaTotalClasses" name="total_classes" class="form-control" min="0" step="1" inputmode="numeric" required>
                        </div>
                        <div class="col-md-6">
                            <label for="metaMinClasses" class="form-label">Quantidade mínima de aulas</label>
                            <input type="number" id="metaMinClasses" name="min_classes" class="form-control" min="0" step="1" inputmode="numeric" required>
                            <div class="form-text">
                                Proporção: <strong id="metaMinClassesPercent">0%</strong>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label mb-0">Selecione as turmas</label>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="selectAllTurmas">Selecionar todas</button>
                        </div>
                        <div class="meta-turma-picker">
                            {{#each turmas}}
                            <label class="meta-turma-card">
                                <input class="form-check-input meta-turma-checkbox" type="checkbox" name="class_codes" value="{{class_code}}">
                                <span class="meta-turma-content">
                                    <span class="meta-turma-name">{{class_name}}</span>
                                </span>
                            </label>
                            {{/each}}
                        </div>
                        <div class="form-text">Marque uma ou mais turmas ativas para aplicar essa meta.</div>
                    </div>

                    <div class="row gy-3">
                        <div class="col-md-6">
                            <label for="metaStartDate" class="form-label">Data de início</label>
                            <input type="text" id="metaStartDate" name="start_date" class="form-control meta-date-input" placeholder="dd/mm/aaaa" inputmode="numeric" autocomplete="off" required>
                        </div>
                        <div class="col-md-6">
                            <label for="metaEndDate" class="form-label">Data de término</label>
                            <input type="text" id="metaEndDate" name="end_date" class="form-control meta-date-input" placeholder="dd/mm/aaaa" inputmode="numeric" autocomplete="off" required>
                        </div>
                    </div>

                    <div class="row gy-3 mt-0">
                        <div class="col-md-6">
                            <label for="metaExamStartDate" class="form-label">Início do período de exame</label>
                            <input type="text" id="metaExamStartDate" name="exam_start_date" class="form-control meta-date-input" placeholder="dd/mm/aaaa" inputmode="numeric" autocomplete="off" required>
                        </div>
                        <div class="col-md-6">
                            <label for="metaExamEndDate" class="form-label">Término do período de exame</label>
                            <input type="text" id="metaExamEndDate" name="exam_end_date" class="form-control meta-date-input" placeholder="dd/mm/aaaa" inputmode="numeric" autocomplete="off" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="sendNoticeCheckbox" checked>
                            <label class="form-check-label" for="sendNoticeCheckbox">
                                Enviar aviso aos alunos matriculados
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary mb-3" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary mb-3">Criar meta de aula</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    #modalNovaMetaAula .modal-body {
        max-height: calc(100vh - 220px);
        overflow-y: auto;
    }

    .meta-turma-picker {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .meta-turma-card {
        display: flex;
        align-items: center;
        padding: 0.75rem;
        border: 1px solid #dee2e6;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .meta-turma-card:hover {
        border-color: #0d6efd;
        background-color: #f0f6ff;
    }

    .meta-turma-card input {
        flex-shrink: 0;
    }

    .meta-turma-card input:checked ~ .meta-turma-content {
        font-weight: 600;
        color: #0d6efd;
    }

    .meta-turma-content {
        margin-left: 0.5rem;
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .meta-turma-name {
        display: block;
        font-size: 0.9rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>

<script>
    document.getElementById('selectAllTurmas')?.addEventListener('click', function (e) {
        e.preventDefault();
        const checkboxes = document.querySelectorAll('.meta-turma-checkbox');
        checkboxes.forEach((checkbox) => checkbox.checked = true);
    });

    const clampNonNegativeInt = (value) => {
        const parsed = parseInt(String(value || '').replace(/[^\d-]/g, ''), 10);
        if (!Number.isFinite(parsed) || Number.isNaN(parsed)) return 0;
        return Math.max(0, parsed);
    };

    const updatePercentLabel = () => {
        const total = clampNonNegativeInt(document.getElementById('metaTotalClasses')?.value);
        const min = clampNonNegativeInt(document.getElementById('metaMinClasses')?.value);
        const percentEl = document.getElementById('metaMinClassesPercent');
        if (!percentEl) return;

        if (total <= 0) {
            percentEl.textContent = '0%';
            return;
        }
        const pct = Math.round((Math.min(min, total) / total) * 100);
        percentEl.textContent = `${pct}%`;
    };

    document.getElementById('metaTotalClasses')?.addEventListener('input', updatePercentLabel);
    document.getElementById('metaMinClasses')?.addEventListener('input', updatePercentLabel);

    const applyDateMask = (inputEl) => {
        if (!inputEl) return;
        inputEl.addEventListener('input', function () {
            const digits = this.value.replace(/\D/g, '').slice(0, 8);
            const dd = digits.slice(0, 2);
            const mm = digits.slice(2, 4);
            const yyyy = digits.slice(4, 8);
            let out = dd;
            if (mm) out += '/' + mm;
            if (yyyy) out += '/' + yyyy;
            this.value = out;
        });
    };

    document.querySelectorAll('.meta-date-input').forEach(applyDateMask);

    // Se vier de /aluno com query openNovaMeta=1, abre o modal automaticamente.
    document.addEventListener('DOMContentLoaded', function () {
        const params = new URLSearchParams(window.location.search);
        if (params.get('openNovaMeta') === '1') {
            const el = document.getElementById('modalNovaMetaAula');
            if (el) {
                const modal = new bootstrap.Modal(el);
                modal.show();
            }
        }
    });

    document.getElementById('formNovaMetaAula')?.addEventListener('submit', function (e) {
        const sendNoticeCheckbox = document.getElementById('sendNoticeCheckbox');
        const noticeInput = document.createElement('input');
        noticeInput.type = 'hidden';
        noticeInput.name = 'send_notice';
        noticeInput.value = sendNoticeCheckbox?.checked ? 'yes' : 'no';
        this.appendChild(noticeInput);
    });
</script>

{{else}}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="fa-solid fa-award"></i> Metas de aula disponíveis</h5>
    </div>
    <div class="card-body">
        {{#if metas.length}}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                </thead>
                <tbody>
                    {{#each metas}}
                    <tr
                        class="meta-row-clickable"
                        role="button"
                        tabindex="0"
                        data-meta-id="{{id}}"
                        data-meta-title="{{title}}"
                        data-meta-description="{{description}}"
                        data-meta-total-classes="{{total_classes}}"
                        data-meta-min-classes="{{min_classes}}"
                        data-meta-min-classes-percent="{{min_classes_percent}}"
                        data-meta-inicio="{{start_date}}"
                        data-meta-termino="{{end_date}}"
                        data-meta-exam-inicio="{{exam_start_date}}"
                        data-meta-exam-termino="{{exam_end_date}}"
                    >
                        <td><strong>{{title}}</strong></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        {{#if pageNumbers.length}}
        <nav aria-label="Paginação de metas">
            <ul class="pagination justify-content-center mt-3 mb-0">
                <li class="page-item {{#if (eq currentPage 1)}}disabled{{/if}}">
                    <a class="page-link" href="/metasdeaula?page={{prevPage}}" aria-label="Anterior">Anterior</a>
                </li>
                {{#each pageNumbers}}
                <li class="page-item {{#if (eq this ../currentPage)}}active{{/if}}">
                    <a class="page-link" href="/metasdeaula?page={{this}}">{{this}}</a>
                </li>
                {{/each}}
                <li class="page-item {{#if (eq currentPage totalPages)}}disabled{{/if}}">
                    <a class="page-link" href="/metasdeaula?page={{nextPage}}" aria-label="Próximo">Próximo</a>
                </li>
            </ul>
        </nav>
        {{/if}}

        {{else}}
        <p class="text-body-secondary mb-0">Nenhuma meta de aula disponível para suas turmas no momento.</p>
        {{/if}}
    </div>
</div>

<div class="modal fade" id="modalDetalheMetaAluno" tabindex="-1" aria-labelledby="metaTitleModal" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="metaTitleModal"></h5>
            </div>
            <div class="modal-body">
                <div id="metaDescriptionModal" class="mb-3 text-body fw-normal" style="white-space: pre-wrap;"></div>
                <div class="small">
                    <p class="mb-1"><strong>Total de Aulas:</strong> <span id="metaTotalAulasModal" class="fw-normal text-body"></span></p>
                    <p class="mb-1"><strong>Quantidade Mínima:</strong> <span id="metaMinAulasModal" class="fw-normal text-body"></span> (<span id="metaMinPercentModal" class="fw-normal text-body"></span>%)</p>
                    <p class="mb-1"><strong>Início:</strong> <span id="metaInicioModal" class="fw-normal text-body"></span></p>
                    <p class="mb-3"><strong>Término:</strong> <span id="metaTerminoModal" class="fw-normal text-body"></span></p>
                    <hr class="my-3">
                    <p class="mb-2"><strong>Período de Exame</strong></p>
                    <p class="mb-1"><strong>Início:</strong> <span id="metaExamInicioModal" class="fw-normal text-body"></span></p>
                    <p class="mb-0"><strong>Término:</strong> <span id="metaExamTerminoModal" class="fw-normal text-body"></span></p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<style>
    .meta-row-clickable {
        cursor: pointer;
        transition: background-color 0.15s ease;
    }

    .meta-row-clickable:hover {
        background-color: #f8f9fa;
    }

    .meta-row-clickable:focus {
        outline: 2px solid #0d6efd;
        outline-offset: -2px;
    }
</style>

<script>
    document.querySelectorAll('.meta-row-clickable').forEach((row) => {
        row.addEventListener('click', function () {
            const title = this.dataset.metaTitle;
            const description = this.dataset.metaDescription;
            const totalClasses = this.dataset.metaTotalClasses;
            const minClasses = this.dataset.metaMinClasses;
            const minPercent = this.dataset.metaMinClassesPercent;
            const inicio = this.dataset.metaInicio;
            const termino = this.dataset.metaTermino;
            const examInicio = this.dataset.metaExamInicio;
            const examTermino = this.dataset.metaExamTermino;

            document.getElementById('metaTitleModal').textContent = title;
            document.getElementById('metaDescriptionModal').textContent = description;
            document.getElementById('metaTotalAulasModal').textContent = totalClasses;
            document.getElementById('metaMinAulasModal').textContent = minClasses;
            document.getElementById('metaMinPercentModal').textContent = minPercent;
            document.getElementById('metaInicioModal').textContent = inicio;
            document.getElementById('metaTerminoModal').textContent = termino;
            document.getElementById('metaExamInicioModal').textContent = examInicio;
            document.getElementById('metaExamTerminoModal').textContent = examTermino;

            const modal = new bootstrap.Modal(document.getElementById('modalDetalheMetaAluno'));
            modal.show();
        });

        row.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                this.click();
            }
        });
    });
</script>
{{/if}}

