<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <h1 class="mb-0">Meu Perfil</h1>
            </div>

            {{#if mensagem}}
                <div class="alert alert-{{#if (eq tipoMensagem 'danger')}}danger{{else}}{{#if (eq tipoMensagem 'success')}}success{{else}}{{#if (eq tipoMensagem 'warning')}}warning{{else}}info{{/if}}{{/if}}{{/if}} alert-dismissible fade show" role="alert">
                    {{mensagem}}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
                </div>
            {{/if}}

            {{#if emailConfirmPreviewLink}}
                <div class="alert alert-info small">
                    <strong>Ambiente sem SMTP:</strong> use este link para simular o e-mail de confirmação:
                    <a href="{{emailConfirmPreviewLink}}">{{emailConfirmPreviewLink}}</a>
                </div>
            {{/if}}

            <div id="meuperfilAlert" class="alert d-none" role="alert"></div>

            <div class="accordion shadow-sm" id="accordionPerfil">
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingAvatar">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAvatar" aria-expanded="false" aria-controls="collapseAvatar">
                            <span class="badge text-bg-primary me-2"><i class="fa-solid fa-image" aria-hidden="true"></i></span>
                            <b>Meu Avatar</b>
                        </button>
                    </h2>
                    <div id="collapseAvatar" class="accordion-collapse collapse" data-bs-parent="#accordionPerfil" aria-labelledby="headingAvatar">
                        <div class="accordion-body text-center">
                            <img id="mpAvatarPreview" src="{{usuario.photo}}" alt="Seu avatar" style="width: 250px; height: 250px; object-fit: cover; border-radius: 16px; border: 2px solid var(--bs-border-color-translucent);">
                            <div class="mt-3">
                                <button type="button" id="mpBtnTrocarAvatar" class="btn btn-outline-primary">Trocar imagem</button>
                            </div>

                            <div id="mpAvatarUploadArea" class="mt-4 text-start d-none">
                                <div class="mb-3">
                                    <input type="file" class="form-control" id="mpAvatarInput" accept="image/jpeg,image/jpg,image/png,image/gif">
                                    <small class="form-text text-muted small">Tamanho máximo de 10 MB e dimensão mínima de 200×200 pixels. Formatos aceitos: JPG, PNG ou GIF.</small>
                                </div>

                                <div id="mpCropContainer" class="mb-3 d-none">
                                    <div class="card">
                                        <div class="card-body">
                                            <h6 class="card-title">Ajuste sua foto</h6>
                                            <div style="max-height: 400px; overflow: hidden; margin-bottom: 15px;">
                                                <img id="mpCropperImage" style="max-width: 100%;">
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button type="button" class="btn btn-sm btn-secondary" id="mpRotateLeft"><i class="fa-solid fa-rotate-left"></i> Girar</button>
                                                <button type="button" class="btn btn-sm btn-success" id="mpCropConfirm"><i class="fa-solid fa-check"></i> Usar esta imagem</button>
                                                <button type="button" class="btn btn-sm btn-danger" id="mpCropCancel"><i class="fa-solid fa-times"></i> Cancelar</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div id="mpAvatarPreviewContainer" class="mb-3 d-none">
                                    <label class="form-label">Prévia da nova foto:</label>
                                    <div style="width: 150px; height: 150px; border: 2px solid #ddd; border-radius: 8px; overflow: hidden;">
                                        <img id="mpAvatarNewPreview" style="width: 100%; height: 100%; object-fit: cover;">
                                    </div>
                                    <div class="mt-2">
                                        <button type="button" id="mpBtnEnviarAvatar" class="btn btn-outline-primary">Enviar avatar</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingDados">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDados" aria-expanded="false" aria-controls="collapseDados">
                            <span class="badge text-bg-primary me-2"><i class="fa-solid fa-address-card" aria-hidden="true"></i></span>
                            <b>Dados Pessoais</b>
                        </button>
                    </h2>
                    <div id="collapseDados" class="accordion-collapse collapse" data-bs-parent="#accordionPerfil" aria-labelledby="headingDados">
                        <div class="accordion-body">
                            <form id="formDadosPessoais" class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="mp_first_name">Primeiro nome</label>
                                    <input type="text" class="form-control" id="mp_first_name" name="first_name" value="{{usuario.first_name}}" required maxlength="120">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="mp_last_name">Restante do nome</label>
                                    <input type="text" class="form-control" id="mp_last_name" name="last_name" value="{{usuario.last_name}}" required maxlength="200">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="mp_phone">WhatsApp <span class="text-muted fw-normal">(apenas números)</span></label>
                                    <input type="text" class="form-control" id="mp_phone" name="phone" value="{{usuario.phone}}" inputmode="numeric" autocomplete="tel" maxlength="11" required placeholder="11999999999" pattern="[0-9]{11}" title="Digite 11 números (DDD + celular), sem espaços ou símbolos.">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="mp_actual_belt">Faixa atual</label>
                                    <select class="form-select" id="mp_actual_belt" name="actual_belt" required>
                                        {{#each beltOptions}}
                                            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="mp_actual_degree">Grau atual</label>
                                    <select class="form-select" id="mp_actual_degree" name="actual_degree" required>
                                        {{#each degreeOptions}}
                                            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="col-12 text-center">
                                    <button type="submit" class="btn btn-outline-primary">Salvar dados pessoais</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingMedidas">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMedidas" aria-expanded="false" aria-controls="collapseMedidas">
                            <span class="badge text-bg-primary me-2"><i class="fa-solid fa-ruler-horizontal" aria-hidden="true"></i></span>
                            <b>Minhas Medidas</b>
                        </button>
                    </h2>
                    <div id="collapseMedidas" class="accordion-collapse collapse" data-bs-parent="#accordionPerfil" aria-labelledby="headingMedidas">
                        <div class="accordion-body">
                            <form id="formMedidas" class="row g-3"> 
                                <div class="col-md-4">
                                    <label class="form-label" for="mp_wagi">Tamanho da Jaqueta (Wagi)</label>
                                    <select class="form-select" id="mp_wagi" name="wagi_size" required>
                                        {{#each kimonoSizeOptions}}
                                            <option value="{{code}}" {{#if (eq ../usuario.wagi_size code)}}selected{{/if}}>{{label}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label" for="mp_zubon">Tamanho da Calça (Zubon)</label>
                                    <select class="form-select" id="mp_zubon" name="zubon_size" required>
                                        {{#each kimonoSizeOptions}}
                                            <option value="{{code}}" {{#if (eq ../usuario.zubon_size code)}}selected{{/if}}>{{label}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label" for="mp_obi">Tamanho da Faixa (Obi)</label>
                                    <select class="form-select" id="mp_obi" name="obi_size" required>
                                        {{#each obiSizeOptions}}
                                            <option value="{{code}}" {{#if (eq ../usuario.obi_size code)}}selected{{/if}}>{{label}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="col-12 text-center">
                                    <button type="submit" class="btn btn-outline-primary">Salvar medidas</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingSeg">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSeg" aria-expanded="false" aria-controls="collapseSeg">
                            <span class="badge text-bg-primary me-2"><i class="fa-solid fa-key" aria-hidden="true"></i></span>
                            <b>Segurança e Login</b>
                        </button>
                    </h2>
                    <div id="collapseSeg" class="accordion-collapse collapse" data-bs-parent="#accordionPerfil" aria-labelledby="headingSeg">
                        <div class="accordion-body text-center">
                            <p>Uma nova tela será exibida por segurança.</p>
                            <button type="button" class="btn text-bg-danger" data-bs-toggle="modal" data-bs-target="#modalSegurancaRisco">
                                Exibir tela segura
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalSegurancaRisco" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalSegurancaRiscoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalSegurancaRiscoLabel">
                    <span class="badge text-bg-primary me-2"><i class="fa-solid fa-asterisk" aria-hidden="true"></i></span> Credenciais de acesso
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div class="text-center text-bg-warning p-3 rounded-3 mb-3">
                    <p>Caso não queira mudar a senha, deixe os campos em branco.</p>
                </div>
                <form id="formSegurancaLogin" class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="mp_login_email">E-mail (login)</label>
                        <input type="email" class="form-control" id="mp_login_email" name="email" value="{{usuario.email}}" autocomplete="username" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="mp_new_pw">Nova senha</label>
                        <div class="input-group">
                            <input type="password" class="form-control mp-pw-field" id="mp_new_pw" name="new_password" autocomplete="new-password" minlength="6">
                            <button class="btn btn-outline-secondary mp-toggle-pw" type="button" title="Mostrar ou ocultar"><i class="fa-solid fa-eye-slash" aria-hidden="true"></i></button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="mp_new_pw2">Repetir a nova senha</label>
                        <div class="input-group">
                            <input type="password" class="form-control mp-pw-field" id="mp_new_pw2" name="new_password_confirm" autocomplete="new-password" minlength="6">
                            <button class="btn btn-outline-secondary mp-toggle-pw" type="button" title="Mostrar ou ocultar"><i class="fa-solid fa-eye-slash" aria-hidden="true"></i></button>
                        </div>
                    </div>
                    <div class="col-12 text-center">
                        <button type="submit" class="btn btn-outline-primary">Salvar dados de acesso</button>
                    </div>
                </form>

                <div id="mpEmailDependentesWarn" class="alert alert-warning mt-3 d-none align-items-start gap-2" role="alert">
                    <div class="flex-grow-1">
                        Se o novo e-mail for validado com sucesso, as contas dependentes à sua serão alteradas automaticamente.
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-dark flex-shrink-0" id="mpEmailDependentesWarnFechar">Fechar definitivamente</button>
                </div>

                {{#if usuario.pending_email}}
                    <div class="mt-3 p-3 border rounded bg-body-tertiary">
                        <p class="small mb-2">Alteração pendente para: <strong>{{usuario.pending_email}}</strong></p>
                        <button type="button" id="btnConfirmarEmail" class="btn text-bg-primary w-100">CONFIRMAR ALTERAÇÃO DO E-MAIL</button>
                        <p class="small text-body-secondary mt-2 mb-0">Ao confirmar, todas as sessões serão encerradas e você deverá entrar com o novo e-mail.</p>
                    </div>
                {{/if}}

                <div id="mpEmailPreviewBox" class="alert alert-info small mt-3 d-none"></div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<script>
(function () {
    const titularTemDependentes = {{#if titularTemDependentesAtivos}}true{{else}}false{{/if}};
    const titularStorageKey = 'meuperfil_aviso_dependentes_email_{{titularDismissStorageId}}';
    const alertBox = document.getElementById('meuperfilAlert');

    function showPageAlert(variant, text) {
        if (!alertBox) return;
        alertBox.className = 'alert alert-' + variant;
        alertBox.textContent = text;
        alertBox.classList.remove('d-none');
    }

    function wirePasswordToggles(root) {
        (root || document).querySelectorAll('.mp-toggle-pw').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const wrap = btn.closest('.input-group');
                const input = wrap ? wrap.querySelector('.mp-pw-field') : null;
                if (!input) return;
                const show = input.type === 'password';
                input.type = show ? 'text' : 'password';
                const icon = btn.querySelector('i');
                if (icon) {
                    icon.className = show ? 'fa-solid fa-eye' : 'fa-solid fa-eye-slash';
                }
            });
        });
    }

    wirePasswordToggles(document);

    const depWarn = document.getElementById('mpEmailDependentesWarn');
    const depWarnBtn = document.getElementById('mpEmailDependentesWarnFechar');
    const emailField = document.getElementById('mp_login_email');

    function refreshDependentesWarning() {
        if (!depWarn || !emailField) return;
        if (!titularTemDependentes) {
            depWarn.classList.add('d-none');
            return;
        }
        if (localStorage.getItem(titularStorageKey) === '1') {
            depWarn.classList.add('d-none');
            return;
        }
        const original = ('{{usuario.email}}' || '').trim().toLowerCase();
        if (emailField.value.trim().toLowerCase() !== original) {
            depWarn.classList.remove('d-none');
        } else {
            depWarn.classList.add('d-none');
        }
    }

    if (emailField) {
        emailField.addEventListener('input', refreshDependentesWarning);
        refreshDependentesWarning();
    }

    if (depWarnBtn) {
        depWarnBtn.addEventListener('click', function () {
            localStorage.setItem(titularStorageKey, '1');
            if (depWarn) depWarn.classList.add('d-none');
        });
    }

    const phoneField = document.getElementById('mp_phone');
    function mpSanitizePhoneDigits(el) {
        if (!el) return;
        const only = el.value.replace(/\D/g, '').slice(0, 11);
        if (el.value !== only) el.value = only;
    }
    if (phoneField) {
        mpSanitizePhoneDigits(phoneField);
        phoneField.addEventListener('input', function () {
            mpSanitizePhoneDigits(phoneField);
        });
    }

    function handleLogoutResponse(data) {
        if (data.logout) {
            window.location.href = '/auth/login';
            return true;
        }
        return false;
    }

    async function postJson(url, body) {
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(body)
        });
        const data = await res.json().catch(function () { return {}; });
        if (!res.ok || !data.ok) {
            throw new Error(data.mensagem || 'Falha na requisição.');
        }
        return data;
    }

    function recarregarMeuPerfilAposSalvar(data) {
        const params = new URLSearchParams();
        params.set('mensagem', data.mensagem || 'Salvo com sucesso.');
        params.set('tipo', 'success');
        if (data.emailPreviewLink) {
            params.set('email_preview_link', data.emailPreviewLink);
        }
        window.location.assign('/meuperfil?' + params.toString());
    }

    document.getElementById('formDadosPessoais')?.addEventListener('submit', async function (e) {
        e.preventDefault();
        try {
            if (phoneField) mpSanitizePhoneDigits(phoneField);
            const fd = new FormData(this);
            const body = Object.fromEntries(fd.entries());
            const phoneVal = String(body.phone || '').trim();
            if (!phoneVal) {
                showPageAlert('danger', 'Informe o WhatsApp com DDD e 11 dígitos.');
                return;
            }
            if (!/^\d+$/.test(phoneVal)) {
                showPageAlert(
                    'danger',
                    'No WhatsApp, use apenas números, sem letras, espaços ou símbolos.'
                );
                return;
            }
            if (phoneVal.length !== 11) {
                showPageAlert('danger', 'Informe o WhatsApp com DDD e 11 dígitos.');
                return;
            }
            const data = await postJson('/meuperfil/dados-pessoais', body);
            recarregarMeuPerfilAposSalvar(data);
        } catch (err) {
            showPageAlert('danger', err.message);
        }
    });

    document.getElementById('formMedidas')?.addEventListener('submit', async function (e) {
        e.preventDefault();
        try {
            const fd = new FormData(this);
            const body = Object.fromEntries(fd.entries());
            const data = await postJson('/meuperfil/medidas', body);
            recarregarMeuPerfilAposSalvar(data);
        } catch (err) {
            showPageAlert('danger', err.message);
        }
    });

    document.getElementById('formSegurancaLogin')?.addEventListener('submit', async function (e) {
        e.preventDefault();
        const previewBox = document.getElementById('mpEmailPreviewBox');
        if (previewBox) {
            previewBox.classList.add('d-none');
            previewBox.textContent = '';
        }
        try {
            const fd = new FormData(this);
            const body = Object.fromEntries(fd.entries());
            const data = await postJson('/meuperfil/seguranca', body);
            if (handleLogoutResponse(data)) return;
            recarregarMeuPerfilAposSalvar(data);
        } catch (err) {
            showPageAlert('danger', err.message);
        }
    });

    document.getElementById('btnConfirmarEmail')?.addEventListener('click', async function () {
        if (!confirm('Confirma a alteração do e-mail? Você será desconectado de todas as sessões.')) {
            return;
        }
        try {
            const data = await postJson('/meuperfil/confirmar-email', {});
            if (handleLogoutResponse(data)) return;
            showPageAlert('success', data.mensagem || 'Concluído.');
        } catch (err) {
            showPageAlert('danger', err.message);
        }
    });

    function atualizarGrausPorFaixa() {
        const beltEl = document.getElementById('mp_actual_belt');
        const degEl = document.getElementById('mp_actual_degree');
        if (!beltEl || !degEl) return;
        const belt = beltEl.value;
        const max = belt === 'black' ? 6 : 4;
        const atual = parseInt(degEl.value, 10);
        degEl.innerHTML = '';
        for (let i = 0; i <= max; i++) {
            const opt = document.createElement('option');
            opt.value = String(i);
            opt.textContent = String(i);
            degEl.appendChild(opt);
        }
        const usar = Number.isFinite(atual) && atual <= max ? atual : max;
        degEl.value = String(usar);
    }

    document.getElementById('mp_actual_belt')?.addEventListener('change', atualizarGrausPorFaixa);

    const avatarInput = document.getElementById('mpAvatarInput');
    const avatarUploadArea = document.getElementById('mpAvatarUploadArea');
    const avatarBtnTrocar = document.getElementById('mpBtnTrocarAvatar');
    const avatarCropContainer = document.getElementById('mpCropContainer');
    const avatarCropperImage = document.getElementById('mpCropperImage');
    const avatarPreviewContainer = document.getElementById('mpAvatarPreviewContainer');
    const avatarNewPreview = document.getElementById('mpAvatarNewPreview');
    const avatarRotateLeftBtn = document.getElementById('mpRotateLeft');
    const avatarCropConfirmBtn = document.getElementById('mpCropConfirm');
    const avatarCropCancelBtn = document.getElementById('mpCropCancel');
    const avatarBtnEnviar = document.getElementById('mpBtnEnviarAvatar');

    let mpCropper = null;
    let mpCroppedBlob = null;

    avatarBtnTrocar?.addEventListener('click', function () {
        avatarUploadArea.classList.toggle('d-none');
    });

    avatarInput?.addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (!file) return;

        if (file.size > 10 * 1024 * 1024) {
            showPageAlert('danger', 'A imagem deve ter no máximo 10 MB.');
            avatarInput.value = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = function (event) {
            const img = new Image();
            img.onload = function () {
                if (img.naturalWidth < 200 || img.naturalHeight < 200) {
                    showPageAlert('danger', 'A imagem deve ter no mínimo 200x200 pixels.');
                    avatarInput.value = '';
                    return;
                }

                avatarCropperImage.src = event.target.result;
                avatarCropContainer.classList.remove('d-none');
                avatarPreviewContainer.classList.add('d-none');

                if (mpCropper) mpCropper.destroy();
                mpCropper = new Cropper(avatarCropperImage, {
                    aspectRatio: 1,
                    viewMode: 1,
                    autoCropArea: 1,
                    responsive: true,
                    guides: true,
                    highlight: true,
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    toggleDragModeOnDblclick: true,
                });
            };
            img.src = event.target.result;
        };
        reader.readAsDataURL(file);
    });

    avatarRotateLeftBtn?.addEventListener('click', function () {
        if (mpCropper) mpCropper.rotate(-90);
    });

    avatarCropConfirmBtn?.addEventListener('click', function () {
        if (!mpCropper) return;
        const canvas = mpCropper.getCroppedCanvas({
            maxWidth: 500,
            maxHeight: 500,
            fillColor: '#fff',
            imageSmoothingEnabled: true,
            imageSmoothingQuality: 'high',
        });
        avatarNewPreview.src = canvas.toDataURL();
        canvas.toBlob(function (blob) {
            mpCroppedBlob = blob;
            avatarCropContainer.classList.add('d-none');
            avatarPreviewContainer.classList.remove('d-none');
        }, 'image/jpeg', 0.80);
    });

    avatarCropCancelBtn?.addEventListener('click', function () {
        avatarInput.value = '';
        avatarCropContainer.classList.add('d-none');
        avatarPreviewContainer.classList.add('d-none');
        mpCroppedBlob = null;
        if (mpCropper) {
            mpCropper.destroy();
            mpCropper = null;
        }
    });

    avatarBtnEnviar?.addEventListener('click', async function () {
        if (!mpCroppedBlob) return;
        avatarBtnEnviar.disabled = true;
        try {
            const fd = new FormData();
            fd.append('photo', mpCroppedBlob, 'avatar.jpg');
            const res = await fetch('/meuperfil/avatar', {
                method: 'POST',
                headers: { Accept: 'application/json' },
                body: fd
            });
            const data = await res.json().catch(function () { return {}; });
            if (!res.ok || !data.ok) {
                throw new Error(data.mensagem || 'Falha ao enviar a imagem.');
            }
            const params = new URLSearchParams();
            params.set('mensagem', data.mensagem || 'Avatar enviado com sucesso.');
            params.set('tipo', data.tipo || 'success');
            window.location.assign('/meuperfil?' + params.toString());
        } catch (err) {
            showPageAlert('danger', err.message);
            avatarBtnEnviar.disabled = false;
        }
    });
})();
</script>
