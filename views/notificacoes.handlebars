{{#if mensagem}}
<div class="alert alert-{{tipoMensagem}} alert-autodismiss" role="alert">
    {{#if (eq tipoMensagem 'danger')}}<i class="fa-solid fa-circle-xmark"></i>{{else}}<i class="fa-solid fa-circle-check"></i>{{/if}} {{mensagem}}
</div>
{{/if}}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h1 class="mb-0">Notificações</h1>
    <div class="d-flex flex-wrap align-items-center gap-2">
        {{#if notificacoes.length}}
        <div class="form-check mb-0">
            <input class="form-check-input" type="checkbox" id="checkSelecionarTodasNotificacoes">
            <label class="form-check-label small" for="checkSelecionarTodasNotificacoes">Selecionar todas</label>
        </div>
        {{/if}}
        <button type="button" class="btn btn-outline-danger btn-sm d-none" id="btnRemoverNotificacoes">
            <i class="fa-solid fa-trash-can"></i> <span id="btnRemoverNotificacoesLabel">Remover</span>
        </button>

    </div>
</div>

<p class="text-body-secondary small mb-3">Aqui aparecem avisos do sistema, por exemplo quando uma solicitação de presença é aprovada ou negada por um professor.</p>

{{#unless notificacoes.length}}
<div class="card border-0 shadow-sm">
    <div class="card-body text-body-secondary text-center py-5">
        <i class="fa-solid fa-bell fs-1 d-block mb-3 opacity-50"></i>
        Nenhuma notificação por enquanto.
    </div>
</div>
{{else}}
<div class="vstack gap-3" id="listaNotificacoes">
    {{#each notificacoes}}
    <div class="card border-0 shadow-sm notificacao-item {{#if isUnread}}border-start border-4 border-primary{{/if}}" data-id="{{id}}" data-unread="{{#if isUnread}}1{{else}}0{{/if}}">
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-start gap-3">
                <div class="form-check mt-1 shrink-0">
                    <input class="form-check-input notificacao-select" type="checkbox" value="{{id}}" id="notifSelect{{id}}" aria-label="Selecionar notificação {{id}}">
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex flex-wrap align-items-start justify-content-between gap-2">
                        <div>
                            <span class="badge text-bg-{{kindBadge}} me-1">
                                {{#if (eq kind 'PRESENCA_APROVADA')}}Presença aprovada{{else}}{{#if (eq kind 'PRESENCA_NEGADA')}}Presença negada{{else}}{{#if (eq kind 'AVATAR_APROVADO')}}Avatar aprovado{{else}}{{#if (eq kind 'AVATAR_NEGADO')}}Avatar negado{{else}}Sistema{{/if}}{{/if}}{{/if}}{{/if}}
                            </span>
                            {{#if isUnread}}<span class="badge text-bg-primary">Nova</span>{{/if}}
                            <h2 class="h6 mt-2 mb-1">{{title}}</h2>
                            <p class="mb-0 text-body-secondary">{{body}}</p>
                            <div class="small text-body-secondary mt-2">
                                <i class="fa-regular fa-clock"></i> {{createdAtLabel}}
                                {{#unless isUnread}}
                                <span class="ms-2"><i class="fa-regular fa-eye"></i> Lida em {{readAtLabel}}</span>
                                {{/unless}}
                            </div>
                        </div>
                        {{#if isUnread}}
                        <button type="button" class="btn btn-sm btn-outline-primary shrink-0 btn-marcar-notificacao-lida" data-id="{{id}}" aria-label="Marcar como lida">
                            <i class="fa-regular fa-envelope-open"></i> Marcar lida
                        </button>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{/each}}
</div>
{{/unless}}

<script>
(function () {
    function showToast(message, variant) {
        const wrap = document.createElement('div');
        wrap.className = 'alert alert-' + (variant === 'danger' ? 'danger' : 'success') + ' alert-autodismiss position-fixed top-0 start-50 translate-middle-x mt-3 shadow';
        wrap.style.zIndex = '2000';
        wrap.setAttribute('role', 'alert');
        wrap.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> ' + message;
        document.body.appendChild(wrap);
        window.setTimeout(function () { wrap.remove(); }, 5000);
    }

    async function postJson(url, body) {
        const options = {
            method: 'POST',
            headers: {
                'Accept': 'application/json',
                'Content-Type': 'application/json'
            }
        };
        if (body !== undefined) {
            options.body = JSON.stringify(body);
        }
        const res = await fetch(url, options);
        const data = await res.json().catch(function () { return {}; });
        if (!res.ok || !data.ok) {
            throw new Error(data.mensagem || 'Falha na requisição.');
        }
        return data;
    }

    function getSelectedNotificationIds() {
        return Array.from(document.querySelectorAll('.notificacao-select:checked'))
            .map(function (input) { return parseInt(input.value, 10); })
            .filter(function (id) { return Number.isInteger(id) && id > 0; });
    }

    function syncRemoveButtonState() {
        const btnRemover = document.getElementById('btnRemoverNotificacoes');
        const btnLabel = document.getElementById('btnRemoverNotificacoesLabel');
        if (!btnRemover || !btnLabel) {
            return;
        }

        const selectedCount = getSelectedNotificationIds().length;
        btnRemover.classList.toggle('d-none', selectedCount === 0);
        btnLabel.textContent = selectedCount === 1 ? 'Remover' : 'Remover Selecionados';
    }

    function syncSelectAllCheckboxState() {
        const checkSelecionarTodas = document.getElementById('checkSelecionarTodasNotificacoes');
        if (!checkSelecionarTodas) {
            return;
        }

        const checkboxes = document.querySelectorAll('.notificacao-select');
        const selectedCount = document.querySelectorAll('.notificacao-select:checked').length;
        checkSelecionarTodas.checked = checkboxes.length > 0 && selectedCount === checkboxes.length;
        checkSelecionarTodas.indeterminate = selectedCount > 0 && selectedCount < checkboxes.length;
    }

    document.querySelectorAll('.notificacao-select').forEach(function (checkbox) {
        checkbox.addEventListener('change', function () {
            syncRemoveButtonState();
            syncSelectAllCheckboxState();
        });
    });

    const checkSelecionarTodas = document.getElementById('checkSelecionarTodasNotificacoes');
    if (checkSelecionarTodas) {
        checkSelecionarTodas.addEventListener('change', function () {
            document.querySelectorAll('.notificacao-select').forEach(function (checkbox) {
                checkbox.checked = checkSelecionarTodas.checked;
            });
            syncRemoveButtonState();
            syncSelectAllCheckboxState();
        });
    }

    const btnRemover = document.getElementById('btnRemoverNotificacoes');
    if (btnRemover) {
        btnRemover.addEventListener('click', async function () {
            const ids = getSelectedNotificationIds();
            if (ids.length === 0) {
                return;
            }

            btnRemover.disabled = true;
            try {
                const data = await postJson('/notificacoes/remover', { ids: ids });
                window.location.href = '/notificacoes?mensagem=' + encodeURIComponent(data.mensagem || 'Notificações removidas.') + '&tipo=success';
            } catch (e) {
                showToast(e.message, 'danger');
                btnRemover.disabled = false;
            }
        });
    }

    const btnTodas = document.getElementById('btnMarcarTodasNotificacoes');
    if (btnTodas) {
        btnTodas.addEventListener('click', async function () {
            btnTodas.disabled = true;
            try {
                await postJson('/notificacoes/marcar-todas-lidas');
                window.location.reload();
            } catch (e) {
                showToast(e.message, 'danger');
                btnTodas.disabled = false;
            }
        });
    }

    document.querySelectorAll('.btn-marcar-notificacao-lida').forEach(function (btn) {
        btn.addEventListener('click', async function () {
            const id = btn.getAttribute('data-id');
            if (!id) return;
            btn.disabled = true;
            try {
                await postJson('/notificacoes/' + encodeURIComponent(id) + '/ler');
                window.location.reload();
            } catch (e) {
                showToast(e.message, 'danger');
                btn.disabled = false;
            }
        });
    });
})();
</script>
