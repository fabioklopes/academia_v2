<div class="container py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-2 mb-3">
        <div>
            <h1 class="mb-1">Relatório por Faixas</h1>
            <div class="text-body-secondary">Ordem decrescente de faixas, com nomes em ordem alfabética dentro do grupo.</div>
        </div>

        <div class="d-flex align-items-center gap-2">
            <a class="btn btn-outline-secondary" href="/relatorios">
                <i class="fa-solid fa-arrow-left"></i> Voltar
            </a>
            <a class="btn btn-outline-danger" href="/relatorios/faixas/download?format=pdf">
                <i class="fa-solid fa-file-pdf"></i> PDF
            </a>
            <a class="btn btn-outline-success" href="/relatorios/faixas/download?format=xlsx">
                <i class="fa-solid fa-file-excel"></i> XLSX
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 relatorio-faixas-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 64px;">Avatar</th>
                            <th>Nome completo</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if alunos.length}}
                            {{#each alunos}}
                            <tr>
                                <td>
                                    <img src="{{photo}}" alt="Avatar de {{full_name}}" class="relatorio-avatar">
                                </td>
                                <td>
                                    <div class="fw-semibold">{{full_name}}</div>
                                    <div class="text-body-secondary small">{{belt_summary_label}}</div>
                                </td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr>
                                <td colspan="2" class="text-center text-body-secondary py-4">Nenhum aluno encontrado.</td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .relatorio-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--bs-border-color-translucent);
    }

    /* remover bordas e manter apenas uma linha fina no rodapé */
    .relatorio-faixas-table > :not(caption) > * > * {
        border-bottom: 1px solid #c0c0c0 !important;
        border-top: 0 !important;
    }
    .relatorio-faixas-table {
        border: 0 !important;
    }
    .belt-badge-white { background: #ececec; color: #111; }
    .belt-badge-gray { background: #686969; color: #fff; }
    .belt-badge-yellow { background: #FECA04; color: #111; }
    .belt-badge-orange { background: #E07E26; color: #111; }
    .belt-badge-green { background: #007F3D; color: #fff; }
    .belt-badge-blue { background: #1890B9; color: #fff; }
    .belt-badge-purple { background: #80298F; color: #fff; }
    .belt-badge-brown { background: #602D11; color: #fff; }
    .belt-badge-black { background: #000000; color: #fff; }
    .belt-badge-red { background: #B01116; color: #fff; }
</style>

