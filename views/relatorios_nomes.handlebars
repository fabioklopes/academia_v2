<div class="container py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-2 mb-3">
        <div>
            <h1 class="mb-1">Relatório por Nomes</h1>
            <div class="text-body-secondary">Ordem alfabética, com alunos ativos primeiro.</div>
        </div>

        <div class="d-flex align-items-center gap-2">
            <a class="btn btn-outline-secondary" href="/relatorios">
                <i class="fa-solid fa-arrow-left"></i> Voltar
            </a>
            <a class="btn btn-outline-danger" href="/relatorios/nomes/download?format=pdf">
                <i class="fa-solid fa-file-pdf"></i> PDF
            </a>
            <a class="btn btn-outline-success" href="/relatorios/nomes/download?format=xlsx">
                <i class="fa-solid fa-file-excel"></i> XLSX
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 64px;">Avatar</th>
                            <th>Nome completo</th>
                            <th class="text-end" style="width: 120px;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if alunos.length}}
                            {{#each alunos}}
                            <tr
                                class="relatorio-aluno-row"
                                role="button"
                                tabindex="0"
                                data-full-name="{{full_name}}"
                                data-photo="{{photo}}"
                                data-belt-image="{{belt_image_path}}"
                                data-birth="{{birth_date_br}}"
                            >
                                <td>
                                    <img src="{{photo}}" alt="Avatar de {{full_name}}" class="relatorio-avatar">
                                </td>
                                <td>
                                    <div class="fw-semibold">{{full_name}}</div>
                                    <div class="text-body-secondary small">{{belt_summary_label}}</div>
                                </td>
                                <td class="text-end">
                                    {{#if is_active}}
                                        <span class="badge text-bg-success">Ativo</span>
                                    {{else}}
                                        <span class="badge text-bg-secondary">Inativo</span>
                                    {{/if}}
                                </td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr>
                                <td colspan="3" class="text-center text-body-secondary py-4">Nenhum aluno encontrado.</td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="relatorioAlunoModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="relatorioAlunoModalTitle">Aluno</h5>
            </div>
            <div class="modal-body text-center">
                <img id="relatorioAlunoModalAvatar" src="/uploads/users/default.jpg" alt="Avatar do aluno" class="rounded-circle relatorio-avatar-lg mb-3">
                <div class="mt-2">
                    <img id="relatorioAlunoModalBelt" src="/img/belts/white_0.png" alt="Faixa do aluno" class="img-fluid relatorio-belt-image">
                </div>
                <div class="mt-3">
                    <div><span class="fw-semibold">Aniversário:</span> <span id="relatorioAlunoModalBirth">-</span></div>
                </div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<style>
    .relatorio-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--bs-border-color-translucent);
    }
    .relatorio-avatar-lg {
        width: 112px;
        height: 112px;
        object-fit: cover;
        border: 2px solid var(--bs-border-color-translucent);
    }
    .relatorio-belt-image {
        max-height: 34px;
    }
    .relatorio-aluno-row {
        cursor: pointer;
    }
</style>

<script>
    (() => {
        document.addEventListener('DOMContentLoaded', () => {
            const modalEl = document.getElementById('relatorioAlunoModal');
            if (!modalEl || !window.bootstrap) return;

            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            const rows = Array.from(document.querySelectorAll('.relatorio-aluno-row'));
            rows.forEach((row) => {
                row.addEventListener('click', () => modal.show(row));
                row.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        modal.show(row);
                    }
                });
            });

            modalEl.addEventListener('show.bs.modal', (event) => {
                const trigger = event.relatedTarget;
                if (!trigger) return;

                const name = trigger.getAttribute('data-full-name') || '-';
                const photo = trigger.getAttribute('data-photo') || '/uploads/users/default.jpg';
                const beltImage = trigger.getAttribute('data-belt-image') || '/img/belts/white_0.png';
                const birth = trigger.getAttribute('data-birth') || '-';

                const title = document.getElementById('relatorioAlunoModalTitle');
                const avatar = document.getElementById('relatorioAlunoModalAvatar');
                const belt = document.getElementById('relatorioAlunoModalBelt');
                const birthEl = document.getElementById('relatorioAlunoModalBirth');

                if (title) title.textContent = name;
                if (avatar) {
                    avatar.src = photo;
                    avatar.alt = `Avatar de ${name}`;
                }
                if (belt) {
                    belt.src = beltImage;
                    belt.alt = `Faixa de ${name}`;
                }
                if (birthEl) birthEl.textContent = birth;
            });
        });
    })();
</script>

