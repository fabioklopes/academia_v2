{{#if mensagem}}
<div class="alert alert-{{tipoMensagem}} alert-autodismiss" role="alert">
    {{#if (eq tipoMensagem 'danger')}}<i class="fa-solid fa-circle-xmark"></i>{{else}}<i class="fa-solid fa-circle-check"></i>{{/if}} {{mensagem}}
</div>
{{/if}}

<style>
    #modalTurmaAlunos .modal-dialog {
        max-width: 680px;
    }

    #modalTurmaAlunos .modal-content {
        max-height: 90vh;
    }

    #modalTurmaAlunos .modal-body {
        overflow: hidden;
    }

    .turma-alunos-scroll {
        max-height: 42vh;
        overflow-y: auto;
    }

    @media (max-width: 768px) {
        #modalTurmaAlunos .modal-content {
            max-height: 86vh;
        }

        .turma-alunos-scroll {
            max-height: 38vh;
        }
    }

    .turma-alunos-pagination-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        max-width: 100%;
    }

    .turma-alunos-pagination-wrapper small {
        text-align: center;
    }

    .turma-alunos-pagination-wrapper > * {
        min-width: 0;
    }

    .turma-alunos-pagination-nav {
        display: flex;
        justify-content: center;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

    .turma-alunos-pagination-nav .pagination {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        width: auto;
        margin-bottom: 0;
    }

    @media (max-width: 768px) {
        .turma-alunos-pagination-nav .page-link {
            padding: 0.25rem 0.5rem;
            font-size: 0.85rem;
        }
    }
</style>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h1 class="mb-0">Turmas</h1>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalNovaTurma">
        <i class="fa-solid fa-folder-plus"></i> Nova Turma
    </button>
</div>

    <div class="col-12 col-lg-7">
        <div class="card h-100 border-0 shadow-sm mb-4">
            <div class="card-header bg-light">
                <i class="fa-solid fa-folder-tree"></i> Turmas ativas
            </div>
            <div class="card-body">
                {{#if turmas.length}}
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Turma</th>
                                <th>Matriculados</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each turmas}}
                            <tr class="turma-row" data-class-code="{{class_code}}" data-class-name="{{class_name}}" data-can-manage="{{#if canManage}}Y{{else}}N{{/if}}" style="cursor:pointer;">
                                <td>{{class_name}}</td>
                                <td>{{enrolled_count}}</td>
                                <td class="text-end">
                                    {{#if canManage}}
                                    <form action="/turmas/desativar/{{class_code}}" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" onclick="event.stopPropagation(); return confirm('Desativar esta turma?');" title="Desativar turma">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                    {{else}}
                                    <span class="text-body-secondary small">Somente visualização</span>
                                    {{/if}}
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <p class="text-body-secondary mb-0">Nenhuma turma ativa cadastrada.</p>
                {{/if}}
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-light d-flex flex-wrap align-items-center justify-content-between gap-2">
        <span><i class="fa-solid fa-user-graduate"></i> Matricular alunos ativos</span>
        <span class="small text-body-secondary">Alunos ativos: {{totalAlunosAtivos}}</span>
    </div>
    <div class="card-body">
        <div class="input-group input-group-sm mb-3">
            <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input type="text" id="alunoSearchInput" class="form-control" placeholder="Pesquisar aluno...">
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <button type="button" class="btn btn-sm btn-outline-primary" id="btnSelectAll">
                <i class="fa-solid fa-check-double"></i> Selecionar todos
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnClearSelection">
                <i class="fa-solid fa-eraser"></i> Limpar seleção
            </button>
            <span class="badge text-bg-primary">Selecionados: <span id="selectedCount">0</span></span>
            <span class="badge text-bg-info">Matriculados na turma escolhida: <span id="selectedClassEnrolledCount">0</span></span>
        </div>

        <form id="formMatricular" action="/turmas/matricular" method="POST">
            <input type="hidden" name="class_code" id="classCodeHidden" value="">

            {{#if alunos.length}}
            <div class="table-responsive" style="max-height: 320px; overflow-y: auto;">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-light" style="position: sticky; top: 0; z-index: 2;">
                        <tr>
                            <th style="width: 46px;">#</th>
                            <th>Aluno</th>
                        </tr>
                    </thead>
                    <tbody id="alunosTableBody">
                        {{#each alunos}}
                        <tr class="aluno-row" data-search="{{full_name}} {{user_code}}">
                            <td>
                                <input
                                    class="form-check-input aluno-checkbox"
                                    type="checkbox"
                                    name="user_codes"
                                    value="{{user_code}}"
                                    id="ck_{{user_code}}"
                                >
                            </td>
                            <td>
                                <label for="ck_{{user_code}}" class="form-label mb-0 d-flex align-items-center gap-2">
                                    <img src="{{avatar}}" alt="Avatar de {{full_name}}" style="width:28px; height:28px; border-radius:50%; object-fit:cover; border:1px solid var(--bs-border-color-translucent);">
                                    <span>{{full_name}}</span>
                                </label>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}
            <p class="text-body-secondary mb-2">Nenhum aluno disponível para matrícula.</p>
            {{/if}}

            <div class="mt-3 text-end">
                <button type="button" class="btn btn-primary" id="btnOpenEnrollModal" {{#unless turmas.length}}disabled{{/unless}}>
                    <i class="fa-solid fa-user-plus"></i> Matricular
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="modalNovaTurma" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalNovaTurmaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form action="/turmas/criar" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalNovaTurmaLabel"><i class="fa-solid fa-folder-plus"></i> Nova Turma</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input
                            type="text"
                            class="form-control"
                            id="class_name"
                            name="class_name"
                            placeholder=""
                            maxlength="100"
                            required
                        >
                        <label for="class_name">Nome da nova turma</label>
                    </div>
                    <p class="small text-body-secondary mb-0">
                        Evite nomes muito parecidos com turmas existentes. O sistema bloqueia permutações e variações sintáticas de nomes semelhantes.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-circle-plus"></i> Criar turma
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalMatricular" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalMatricularLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalMatricularLabel">Confirmar Matrícula</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <p class="small text-body-secondary">Selecione a turma para os alunos selecionados</p>
                <div class="form-floating">
                    <select class="form-select" id="classCodeSelectModal" required>
                        <option value="">-- Selecione --</option>
                        {{#each turmas}}
                        <option value="{{class_code}}" data-enrolled-count="{{enrolled_count}}">{{class_name}} </option>
                        {{/each}}
                    </select>
                    <label for="classCodeSelectModal">Turma</label>
                </div>
                <p class="mt-3 mb-0">Alunos selecionados: <strong id="selectedCountModal">0</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnConfirmMatricula">Confirmar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalTurmaAlunos" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalTurmaAlunosLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered">
        <div class="modal-content">
            <form action="/turmas/remover-alunos" method="POST" id="formRemoverAlunosTurma">
                <input type="hidden" name="class_code" id="removeClassCodeHidden" value="">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTurmaAlunosLabel">Alunos Matriculados</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-body-secondary mb-3" id="turmaSelecionadaNome"></p>
                    <div class="turma-alunos-scroll">
                        <div id="turmaAlunosLista" class="list-group"></div>
                    </div>
                    <div id="turmaAlunosPaginationWrap" class="turma-alunos-pagination-wrapper d-flex flex-column align-items-center gap-2 mt-3 d-none">
                        <small class="text-body-secondary">Total de registros: <span id="turmaAlunosTotalItems">0</span></small>
                        <nav class="turma-alunos-pagination-nav" aria-label="Paginação de alunos da turma">
                            <ul class="pagination pagination-sm mb-0" id="turmaAlunosPaginationUl"></ul>
                        </nav>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger" id="btnRemoverAlunosTurma">Remover Aluno(s)</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
(() => {
    document.addEventListener('DOMContentLoaded', () => {
    const checkboxes = Array.from(document.querySelectorAll('.aluno-checkbox'));
    const selectedCount = document.getElementById('selectedCount');
    const selectedCountModal = document.getElementById('selectedCountModal');
    const classCodeSelectModal = document.getElementById('classCodeSelectModal');
    const selectedClassEnrolledCount = document.getElementById('selectedClassEnrolledCount');
    const classCodeHidden = document.getElementById('classCodeHidden');
    const formMatricular = document.getElementById('formMatricular');
    const btnSelectAll = document.getElementById('btnSelectAll');
    const btnClearSelection = document.getElementById('btnClearSelection');
    const btnOpenEnrollModal = document.getElementById('btnOpenEnrollModal');
    const btnConfirmMatricula = document.getElementById('btnConfirmMatricula');
    const modalEl = document.getElementById('modalMatricular');
    const alunoSearchInput = document.getElementById('alunoSearchInput');
    const alunoRows = Array.from(document.querySelectorAll('.aluno-row'));
    const turmaRows = Array.from(document.querySelectorAll('.turma-row'));
    const turmaModalEl = document.getElementById('modalTurmaAlunos');
    const turmaNomeEl = document.getElementById('turmaSelecionadaNome');
    const turmaAlunosListaEl = document.getElementById('turmaAlunosLista');
    const removeClassCodeHidden = document.getElementById('removeClassCodeHidden');
    const btnRemoverAlunosTurma = document.getElementById('btnRemoverAlunosTurma');
    const turmaAlunosPaginationWrap = document.getElementById('turmaAlunosPaginationWrap');
    const turmaAlunosTotalItems = document.getElementById('turmaAlunosTotalItems');
    const turmaAlunosPaginationUl = document.getElementById('turmaAlunosPaginationUl');

    let turmaModalContext = {
        classCode: '',
        className: '',
        canManage: false
    };

    if (!formMatricular || !btnOpenEnrollModal || !modalEl) {
        return;
    }

    function updateSelectedCounter() {
        const count = checkboxes.filter((item) => item.checked).length;
        if (selectedCount) selectedCount.textContent = String(count);
        if (selectedCountModal) selectedCountModal.textContent = String(count);
    }

    function renderTurmaMatriculadosLista(alunos, canManage, totalItems) {
        if (!turmaAlunosListaEl || !turmaNomeEl || !removeClassCodeHidden) {
            return;
        }

        turmaNomeEl.textContent = `${turmaModalContext.className} — ${totalItems} aluno(s) matriculado(s)`;
        removeClassCodeHidden.value = turmaModalContext.classCode;
        turmaAlunosListaEl.innerHTML = '';

        if (!alunos.length) {
            turmaAlunosListaEl.innerHTML = '<div class="text-body-secondary small">Nenhum aluno matriculado nesta turma.</div>';
            if (btnRemoverAlunosTurma) {
                btnRemoverAlunosTurma.disabled = true;
            }
            return;
        }

        alunos.forEach((aluno) => {
            const row = document.createElement('label');
            row.className = 'list-group-item d-flex align-items-center gap-2';

            const checkbox = document.createElement('input');
            checkbox.className = 'form-check-input me-1';
            checkbox.type = 'checkbox';
            checkbox.name = 'user_codes';
            checkbox.value = aluno.user_code;
            checkbox.disabled = !canManage;

            const avatar = document.createElement('img');
            avatar.src = aluno.avatar || '/uploads/users/default.jpg';
            avatar.alt = `Avatar de ${aluno.full_name}`;
            avatar.style.width = '28px';
            avatar.style.height = '28px';
            avatar.style.objectFit = 'cover';
            avatar.style.borderRadius = '50%';
            avatar.style.border = '1px solid var(--bs-border-color-translucent)';

            const name = document.createElement('span');
            name.textContent = aluno.full_name;

            row.appendChild(checkbox);
            row.appendChild(avatar);
            row.appendChild(name);
            turmaAlunosListaEl.appendChild(row);
        });

        if (btnRemoverAlunosTurma) {
            btnRemoverAlunosTurma.disabled = !canManage;
        }
    }

    function renderTurmaMatriculadosPagination(pagination) {
        if (!turmaAlunosPaginationWrap || !turmaAlunosTotalItems || !turmaAlunosPaginationUl) {
            return;
        }

        turmaAlunosTotalItems.textContent = String(pagination.totalItems);
        turmaAlunosPaginationUl.innerHTML = '';

        if (pagination.totalItems === 0) {
            turmaAlunosPaginationWrap.classList.add('d-none');
            return;
        }

        turmaAlunosPaginationWrap.classList.remove('d-none');

        const { classCode } = turmaModalContext;
        const { className } = turmaModalContext;
        const { canManage } = turmaModalContext;

        const appendPageButton = (label, pageNum, disabled, isActive) => {
            const li = document.createElement('li');
            li.className = 'page-item';
            if (disabled) {
                li.classList.add('disabled');
            }
            if (isActive) {
                li.classList.add('active');
            }

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'page-link';
            btn.textContent = label;
            if (disabled || isActive) {
                btn.disabled = true;
            } else {
                btn.addEventListener('click', () => {
                    loadTurmaMatriculados(classCode, className, canManage, pageNum);
                });
            }
            li.appendChild(btn);
            turmaAlunosPaginationUl.appendChild(li);
        };

        appendPageButton('Anterior', pagination.prevPage, !pagination.hasPrev, false);

        (pagination.pageNumbers || []).forEach((pn) => {
            appendPageButton(String(pn.number), pn.number, false, !!pn.isCurrent);
        });

        appendPageButton('Próxima', pagination.nextPage, !pagination.hasNext, false);
    }

    async function loadTurmaMatriculados(classCode, className, canManage, page) {
        if (!turmaAlunosListaEl || !turmaNomeEl || !removeClassCodeHidden) {
            return;
        }

        turmaModalContext = { classCode, className, canManage };

        turmaNomeEl.textContent = `${className} — carregando…`;
        turmaAlunosListaEl.innerHTML = '<div class="text-body-secondary small">Carregando alunos…</div>';
        if (turmaAlunosPaginationWrap) {
            turmaAlunosPaginationWrap.classList.add('d-none');
        }
        if (btnRemoverAlunosTurma) {
            btnRemoverAlunosTurma.disabled = true;
        }

        try {
            const url = `/turmas/matriculados/${encodeURIComponent(classCode)}?page=${encodeURIComponent(String(page))}`;
            const response = await fetch(url, { credentials: 'same-origin', headers: { Accept: 'application/json' } });
            const data = await response.json();

            if (!response.ok || !data.ok) {
                throw new Error(data.mensagem || 'Não foi possível carregar os alunos.');
            }

            renderTurmaMatriculadosLista(data.alunos || [], canManage, data.pagination ? data.pagination.totalItems : 0);
            if (data.pagination) {
                renderTurmaMatriculadosPagination(data.pagination);
            }
        } catch (err) {
            turmaNomeEl.textContent = `${className}`;
            turmaAlunosListaEl.innerHTML = `<div class="text-danger small">${err.message || 'Erro ao carregar.'}</div>`;
            if (turmaAlunosPaginationWrap) {
                turmaAlunosPaginationWrap.classList.add('d-none');
            }
        }
    }

    if (turmaRows.length > 0 && turmaModalEl && window.bootstrap && bootstrap.Modal) {
        turmaRows.forEach((row) => {
            row.addEventListener('click', () => {
                const classCode = row.getAttribute('data-class-code') || '';
                const className = row.getAttribute('data-class-name') || '';
                const canManage = row.getAttribute('data-can-manage') === 'Y';

                loadTurmaMatriculados(classCode, className, canManage, 1);
                const bsTurmaModal = bootstrap.Modal.getOrCreateInstance(turmaModalEl);
                bsTurmaModal.show();
            });
        });
    }

    const formRemoverAlunosTurma = document.getElementById('formRemoverAlunosTurma');
    if (formRemoverAlunosTurma) {
        formRemoverAlunosTurma.addEventListener('submit', (event) => {
            const selecionados = formRemoverAlunosTurma.querySelectorAll('input[name="user_codes"]:checked');
            if (selecionados.length === 0) {
                event.preventDefault();
                alert('Selecione ao menos um aluno para remover da turma.');
                return;
            }

            if (!confirm('Remover aluno(s) selecionado(s) desta turma?')) {
                event.preventDefault();
            }
        });
    }

    if (alunoSearchInput) {
        alunoSearchInput.addEventListener('input', () => {
            const term = String(alunoSearchInput.value || '').trim().toLowerCase();
            alunoRows.forEach((row) => {
                const haystack = String(row.getAttribute('data-search') || '').toLowerCase();
                row.style.display = !term || haystack.includes(term) ? '' : 'none';
            });
        });
    }

    function updateClassCounter() {
        if (!classCodeSelectModal || !selectedClassEnrolledCount) {
            return;
        }
        const option = classCodeSelectModal.options[classCodeSelectModal.selectedIndex];
        const count = option ? option.getAttribute('data-enrolled-count') || '0' : '0';
        selectedClassEnrolledCount.textContent = count;
    }

    checkboxes.forEach((checkbox) => {
        checkbox.addEventListener('change', updateSelectedCounter);
    });

    if (btnSelectAll) {
        btnSelectAll.addEventListener('click', () => {
            checkboxes.forEach((checkbox) => { checkbox.checked = true; });
            updateSelectedCounter();
        });
    }

    if (btnClearSelection) {
        btnClearSelection.addEventListener('click', () => {
            checkboxes.forEach((checkbox) => { checkbox.checked = false; });
            updateSelectedCounter();
        });
    }

    if (classCodeSelectModal) {
        classCodeSelectModal.addEventListener('change', updateClassCounter);
        updateClassCounter();
    }

    btnOpenEnrollModal.addEventListener('click', () => {
        const count = checkboxes.filter((item) => item.checked).length;
        if (count === 0) {
            alert('Selecione ao menos um aluno para matricular.');
            return;
        }

        if (!window.bootstrap || !bootstrap.Modal) {
            alert('Nao foi possivel abrir o modal no momento. Atualize a pagina e tente novamente.');
            return;
        }

        const bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);
        if (!bsModal) {
            return;
        }

        updateSelectedCounter();
        bsModal.show();
    });

    btnConfirmMatricula.addEventListener('click', () => {
        const selectedClassCode = classCodeSelectModal ? String(classCodeSelectModal.value || '').trim() : '';
        if (!selectedClassCode) {
            alert('Selecione a turma para confirmar a matricula.');
            return;
        }

        classCodeHidden.value = selectedClassCode;
        formMatricular.submit();
    });

    updateSelectedCounter();
    });
})();
</script>
